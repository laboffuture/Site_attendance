<%- include('../partials/app-top', { title: title, active: active }) %>
<%
  function ts(d) { return d ? new Date(d).toLocaleString("en-GB", { timeZone: "Asia/Kolkata", dateStyle: "medium", timeStyle: "short" }) : ""; }
  var typeLabel = { wrong_site_scan: "Wrong-site scan", missed_clockout: "Missed clock-out", forgot_submit: "Forgot to submit" };
%>

<div class="oh-page-header">
  <h1 class="oh-page-title">Flagged events</h1>
  <p class="oh-page-subtitle">Wrong-site scan attempts and other anomalies for your sites.</p>
</div>

<div class="oh-filter-tabs">
  <a class="oh-filter-tab <%= !showResolved ? 'oh-filter-tab--active' : '' %>" href="/flags">Unresolved</a>
  <a class="oh-filter-tab <%= showResolved ? 'oh-filter-tab--active' : '' %>" href="/flags?status=resolved">Resolved</a>
</div>

<!-- mobile: flag cards -->
<div class="oh-only-mobile oh-m-section">
  <% if (flags.length) { %>
  <div class="oh-m-list">
    <% flags.forEach(function (f) { %>
    <div class="oh-m-card">
      <div class="oh-m-row" style="margin-bottom:0.5rem;">
        <span class="material-icons" style="font-size:20px;color:#b3261e;">flag</span>
        <span class="oh-m-badge oh-badge--danger"><%= typeLabel[f.type] || f.type %></span>
      </div>
      <div class="oh-m-name"><%= f.workerName || f.attemptedSiteName || "—" %><% if (f.type === "forgot_submit" && f.date) { %> · <%= f.date %><% } %></div>
      <div class="oh-m-sub"><%= f.attemptedSiteName || "—" %><% if (f.homeSiteName && f.type !== "forgot_submit") { %> · assigned <%= f.homeSiteName %><% } %></div>
      <div class="oh-m-sub"><%= ts(f.timestamp) %></div>
      <% if (f.type === "missed_clockout") { %>
      <div class="oh-m-sub" style="margin-top:0.35rem"><a href="<%= (f.homeSiteId && f.date) ? '/regularization/' + f.homeSiteId + '/' + f.date : '/regularization' %>">Fix attendance →</a></div>
      <% } %>
      <% if (f.type === "forgot_submit") { %>
      <div class="oh-m-sub" style="margin-top:0.35rem"><a href="<%= (f.homeSiteId && f.date) ? '/attendance/submit?siteId=' + f.homeSiteId + '&date=' + f.date : '/attendance/submit' %>">Submit day →</a></div>
      <% } %>
      <% if (!showResolved) { %>
      <form method="post" action="/flags/<%= f._id %>/resolve" class="oh-m-actions">
        <button class="oh-btn oh-btn--small oh-btn--success" type="submit">Resolve</button>
      </form>
      <% } %>
    </div>
    <% }); %>
  </div>
  <% } else { %>
  <p class="oh-muted">No <%= showResolved ? "resolved" : "unresolved" %> flags.</p>
  <% } %>
</div>

<div class="oh-card oh-only-desktop">
  <% if (flags.length) { %>
  <table class="oh-table">
    <thead>
      <tr><th>When</th><th>Type</th><th>Worker</th><th>Attempted at</th><th>Assigned to</th><% if (!showResolved) { %><th class="oh-col-action"></th><% } %></tr>
    </thead>
    <tbody>
      <% flags.forEach(function (f) { %>
      <tr>
        <td><%= ts(f.timestamp) %></td>
        <td>
          <span class="oh-badge oh-badge--danger"><%= typeLabel[f.type] || f.type %></span>
          <% if (f.type === "missed_clockout") { %><div style="margin-top:0.3rem;font-size:0.8rem"><a href="<%= (f.homeSiteId && f.date) ? '/regularization/' + f.homeSiteId + '/' + f.date : '/regularization' %>">Fix attendance →</a></div><% } %>
          <% if (f.type === "forgot_submit") { %><div style="margin-top:0.3rem;font-size:0.8rem"><a href="<%= (f.homeSiteId && f.date) ? '/attendance/submit?siteId=' + f.homeSiteId + '&date=' + f.date : '/attendance/submit' %>">Submit day →</a></div><% } %>
        </td>
        <td><%= f.workerName || "—" %></td>
        <td><%= f.attemptedSiteName || "—" %></td>
        <td><%= f.homeSiteName || "—" %></td>
        <% if (!showResolved) { %>
        <td class="oh-col-action">
          <form method="post" action="/flags/<%= f._id %>/resolve" style="margin:0">
            <button class="oh-btn oh-btn--small" type="submit">Resolve</button>
          </form>
        </td>
        <% } %>
      </tr>
      <% }); %>
    </tbody>
  </table>
  <% } else { %>
  <p class="oh-muted">No <%= showResolved ? "resolved" : "unresolved" %> flags.</p>
  <% } %>
</div>

<%- include('../partials/app-bottom') %>
