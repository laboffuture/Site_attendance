<%- include('../partials/app-top', { title: title, active: active }) %>
<%
  function ts(d) { return d ? new Date(d).toLocaleString("en-GB", { timeZone: "Asia/Kolkata", dateStyle: "medium", timeStyle: "short" }) : ""; }
  var typeLabel = { wrong_site_scan: "Wrong-site scan", missed_clockout: "Missed clock-out", forgot_submit: "Forgot to submit" };
%>

<div class="oh-page-header">
  <h1 class="oh-page-title">Flagged events</h1>
  <p class="oh-page-subtitle">Anomalies for your sites. Fix one here and its flag clears itself.</p>
</div>

<div class="oh-filter-tabs">
  <a class="oh-filter-tab <%= !showResolved ? 'oh-filter-tab--active' : '' %>" href="/flags">Unresolved</a>
  <a class="oh-filter-tab <%= showResolved ? 'oh-filter-tab--active' : '' %>" href="/flags?status=resolved">Resolved</a>
</div>

<!-- mobile: flag cards -->
<div class="oh-only-mobile oh-m-section">
  <% if (flags.length) { %>
  <div class="oh-m-list">
    <% flags.forEach(function (f) { %>
    <div class="oh-m-card">
      <div class="oh-m-row" style="margin-bottom:0.5rem;">
        <span class="material-icons" style="font-size:20px;color:#b3261e;">flag</span>
        <span class="oh-m-badge oh-badge--danger"><%= typeLabel[f.type] || f.type %></span>
      </div>
      <div class="oh-m-name"><%= f.workerName || f.attemptedSiteName || "—" %><% if (f.type === "forgot_submit" && f.date) { %> · <%= f.date %><% } %></div>
      <div class="oh-m-sub"><%= f.attemptedSiteName || "—" %><% if (f.homeSiteName && f.type !== "forgot_submit") { %> · assigned <%= f.homeSiteName %><% } %></div>
      <div class="oh-m-sub"><%= ts(f.timestamp) %></div>
      <% if (!showResolved) { %>
      <div class="oh-flag-fix" style="margin-top:0.5rem">
        <% if (f.type === "missed_clockout") { %>
        <form method="post" action="/flags/<%= f._id %>/fix-clockout" class="oh-flag-fix__form">
          <input class="oh-input oh-time24" type="text" name="outHM" required inputmode="numeric" placeholder="HH:MM" pattern="([01][0-9]|2[0-3]):[0-5][0-9]" maxlength="5" aria-label="Clock-out time" />
          <button class="oh-btn oh-btn--small oh-btn--success" type="submit">Fix &amp; resolve</button>
        </form>
        <% if (can("correct_attendance")) { %><a class="oh-flag-fix__more" href="<%= (f.homeSiteId && f.date) ? '/regularization/' + f.homeSiteId + '/' + f.date : '/regularization' %>">Open full editor →</a><% } %>
        <% } else if (f.type === "forgot_submit") { %>
        <form method="post" action="/flags/<%= f._id %>/submit-day" class="oh-flag-fix__form">
          <button class="oh-btn oh-btn--small oh-btn--success" type="submit">Submit day &amp; resolve</button>
        </form>
        <% if (can("submit_attendance")) { %><a class="oh-flag-fix__more" href="<%= (f.homeSiteId && f.date) ? '/attendance/submit?siteId=' + f.homeSiteId + '&date=' + f.date : '/attendance/submit' %>">Open submit screen →</a><% } %>
        <% } else { %>
        <form method="post" action="/flags/<%= f._id %>/resolve" class="oh-flag-fix__form">
          <button class="oh-btn oh-btn--small oh-btn--success" type="submit">Acknowledge</button>
        </form>
        <% } %>
      </div>
      <% } %>
    </div>
    <% }); %>
  </div>
  <% } else { %>
  <p class="oh-muted">No <%= showResolved ? "resolved" : "unresolved" %> flags.</p>
  <% } %>
</div>

<div class="oh-card oh-only-desktop">
  <% if (flags.length) { %>
  <table class="oh-table">
    <thead>
      <tr><th>When</th><th>Type</th><th>Worker</th><th>Attempted at</th><th>Assigned to</th><% if (!showResolved) { %><th class="oh-col-action"></th><% } %></tr>
    </thead>
    <tbody>
      <% flags.forEach(function (f) { %>
      <tr>
        <td><%= ts(f.timestamp) %></td>
        <td>
          <span class="oh-badge oh-badge--danger"><%= typeLabel[f.type] || f.type %></span>
        </td>
        <td><%= f.workerName || "—" %></td>
        <td><%= f.attemptedSiteName || "—" %></td>
        <td><%= f.homeSiteName || "—" %></td>
        <% if (!showResolved) { %>
        <td class="oh-col-action">
          <div class="oh-flag-fix">
            <% if (f.type === "missed_clockout") { %>
            <form method="post" action="/flags/<%= f._id %>/fix-clockout" class="oh-flag-fix__form">
              <input class="oh-input oh-time24" type="text" name="outHM" required inputmode="numeric" placeholder="HH:MM" pattern="([01][0-9]|2[0-3]):[0-5][0-9]" maxlength="5" aria-label="Clock-out time" />
              <button class="oh-btn oh-btn--small oh-btn--success" type="submit">Fix &amp; resolve</button>
            </form>
            <% if (can("correct_attendance")) { %><a class="oh-flag-fix__more" href="<%= (f.homeSiteId && f.date) ? '/regularization/' + f.homeSiteId + '/' + f.date : '/regularization' %>">Full editor →</a><% } %>
            <% } else if (f.type === "forgot_submit") { %>
            <form method="post" action="/flags/<%= f._id %>/submit-day" class="oh-flag-fix__form">
              <button class="oh-btn oh-btn--small oh-btn--success" type="submit">Submit day &amp; resolve</button>
            </form>
            <% if (can("submit_attendance")) { %><a class="oh-flag-fix__more" href="<%= (f.homeSiteId && f.date) ? '/attendance/submit?siteId=' + f.homeSiteId + '&date=' + f.date : '/attendance/submit' %>">Submit screen →</a><% } %>
            <% } else { %>
            <form method="post" action="/flags/<%= f._id %>/resolve" class="oh-flag-fix__form">
              <button class="oh-btn oh-btn--small oh-btn--success" type="submit">Acknowledge</button>
            </form>
            <% } %>
          </div>
        </td>
        <% } %>
      </tr>
      <% }); %>
    </tbody>
  </table>
  <% } else { %>
  <p class="oh-muted">No <%= showResolved ? "resolved" : "unresolved" %> flags.</p>
  <% } %>
</div>

<%- include('../partials/app-bottom') %>
