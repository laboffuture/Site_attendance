<%- include('../partials/app-top', { title: title, active: active }) %>

<div class="oh-detail-topbar">
  <%- include('../partials/breadcrumb', { back: '/workers', trail: [ { label: 'Employees', href: '/workers' }, { label: 'Delete employees' } ] }) %>
</div>

<div class="oh-card oh-form-card">
  <h2 class="oh-section-title"><%= workers.length %> employee(s) selected</h2>
  <div class="oh-alert oh-alert--warning">
    <% workers.slice(0, 12).forEach(function (w, i) { %><%= i ? ', ' : '' %><strong><%= w.name %></strong> (<%= w.empRegNo %>)<% }); %><% if (workers.length > 12) { %> … and <%= workers.length - 12 %> more<% } %>
  </div>

  <form method="post" action="/workers/bulk/delete">
    <input type="hidden" name="ids" value="<%= ids %>" />
    <div class="oh-form-section">
      <h3 class="oh-kv-section__title">What should happen to them?</h3>
      <label class="oh-choice">
        <input type="radio" name="mode" value="archive" checked />
        <span class="oh-choice__body">
          <strong>Send to Archives</strong> (recommended)
          <span class="oh-muted">Hidden from active lists, visible in the Archived tab, restorable any time. All history kept.</span>
        </span>
      </label>
      <label class="oh-choice">
        <input type="radio" name="mode" value="delete" />
        <span class="oh-choice__body">
          <strong>Delete</strong>
          <span class="oh-muted">Removed from the whole application, including Archives. Each employee gets a permanent entry in the Deletion log; only Management can undo. Attendance &amp; payroll history stays intact.</span>
        </span>
      </label>
    </div>

    <div class="oh-input-group">
      <label class="oh-label" for="reason">Reason (required, applies to all selected)</label>
      <input class="oh-input" id="reason" name="reason" required placeholder="e.g. contract ended" />
    </div>

    <div class="oh-form-actions">
      <a class="oh-btn oh-btn--small" href="/workers">Cancel</a>
      <button class="oh-btn oh-btn--danger" type="submit">Confirm for <%= workers.length %> employee(s)</button>
    </div>
  </form>
</div>

<%- include('../partials/app-bottom') %>
