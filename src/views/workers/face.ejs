<%- include('../partials/app-top', { title: title, active: active }) %>

<%- include('../partials/breadcrumb', { back: '/workers?face=unregistered', trail: [ { label: 'Employees', href: '/workers' }, { label: worker.name, href: '/workers/' + worker._id }, { label: 'Register Face' } ] }) %>
<div class="oh-page-header oh-page-header--row">
  <div>
    <h1 class="oh-page-title">Register face</h1>
    <p class="oh-page-subtitle"><%= worker.name %> · <%= worker.empRegNo %> · <%= worker.siteName %></p>
  </div>
</div>

<div class="oh-card oh-form-card oh-form-card--wide">
  <% if (hasFace) { %>
  <p class="oh-muted">A face is already enrolled — this worker can be scanned. Capture again to replace it.</p>
  <% } else { %>
  <p class="oh-muted">No face enrolled yet — capture one clear photo so <%= worker.name %> can be scanned for attendance.</p>
  <% } %>
  <form method="post" action="/workers/<%= worker._id %>/face">
    <input type="hidden" name="returnTo" value="roster" />
    <div class="oh-webcam-wrap">
      <video id="video" class="oh-webcam" autoplay playsinline muted></video>
      <img id="preview" class="oh-shot" src="<%= worker.photoUrl || '' %>" alt="captured photo" <%= worker.photoUrl ? '' : 'hidden' %> />
    </div>
    <canvas id="canvas" hidden></canvas>
    <div class="oh-capture-row">
      <button type="button" class="oh-btn oh-btn--small" id="captureBtn">Capture</button>
      <label class="oh-btn oh-btn--small" for="fileInput">Upload instead</label>
      <input id="fileInput" type="file" accept="image/*" hidden />
      <span id="camNote" class="oh-muted"></span>
    </div>
    <input type="hidden" name="photoData" id="photoData" />
    <div class="oh-form-actions">
      <button class="oh-btn oh-btn--secondary" type="submit" id="submitBtn" disabled>Save face</button>
    </div>
  </form>
</div>

<script src="/static/js/cam-switch.js"></script>
<script src="/static/js/enroll.js"></script>
<%- include('../partials/app-bottom') %>
