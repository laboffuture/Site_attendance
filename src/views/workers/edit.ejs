<%- include('../partials/app-top', { title: title, active: active }) %>

<div class="oh-page-header">
  <h1 class="oh-page-title">Edit employee</h1>
  <p class="oh-page-subtitle"><%= worker.empRegNo %> · <%= worker.designationName %></p>
</div>

<div class="oh-card oh-form-card">
  <form class="oh-form-group" method="post" action="/workers/<%= worker._id %>">
    <div class="oh-row-2">
      <div class="oh-input-group">
        <label class="oh-label" for="empRegNo">Employee ID</label>
        <input class="oh-input" id="empRegNo" value="<%= worker.empRegNo %>" readonly title="Employee ID can't be changed after creation" />
      </div>
      <div class="oh-input-group">
        <label class="oh-label" for="name">Name</label>
        <input class="oh-input" id="name" name="name" value="<%= worker.name %>" required />
      </div>
    </div>

    <div class="oh-row-2">
      <div class="oh-input-group">
        <label class="oh-label" for="designationId">Designation</label>
        <select class="oh-select" id="designationId" name="designationId">
          <option value="">— select —</option>
          <% designations.forEach(function (d) { %>
          <option value="<%= d._id %>" <%= String(d._id) === String(worker.designationId) ? "selected" : "" %>><%= d.name %></option>
          <% }); %>
        </select>
      </div>
      <div class="oh-input-group">
        <label class="oh-label" for="newDesignation">…or new designation</label>
        <input class="oh-input" id="newDesignation" name="newDesignation" placeholder="e.g. Glazier" />
      </div>
    </div>

    <div class="oh-input-group">
      <label class="oh-label" for="siteId">Project site</label>
      <select class="oh-select" id="siteId" name="siteId" required>
        <% sites.forEach(function (s) { %>
        <option value="<%= s._id %>" <%= String(s._id) === String(worker.siteId) ? "selected" : "" %>><%= s.name %> (<%= s.code %>)</option>
        <% }); %>
      </select>
    </div>

    <div class="oh-row-2">
      <div class="oh-input-group">
        <label class="oh-label" for="status">Status</label>
        <select class="oh-select" id="status" name="status">
          <option value="active" <%= worker.status === "active" ? "selected" : "" %>>active</option>
          <option value="inactive" <%= worker.status === "inactive" ? "selected" : "" %>>inactive</option>
        </select>
      </div>
      <div class="oh-input-group">
        <label class="oh-label" for="dateJoined">Date of joining</label>
        <input class="oh-input" id="dateJoined" name="dateJoined" type="date" value="<%= worker.dateJoined ? new Date(worker.dateJoined).toISOString().slice(0,10) : '' %>" />
      </div>
    </div>

    <div class="oh-row-2">
      <div class="oh-input-group">
        <label class="oh-label" for="phone">Phone</label>
        <input class="oh-input" id="phone" name="phone" value="<%= worker.phone || '' %>" placeholder="optional" />
      </div>
      <div class="oh-input-group">
        <label class="oh-label" for="emergencyPhone">Emergency phone</label>
        <input class="oh-input" id="emergencyPhone" name="emergencyPhone" value="<%= worker.emergencyPhone || '' %>" placeholder="optional" />
      </div>
    </div>
    <div class="oh-input-group">
      <label class="oh-label" for="email">Email</label>
      <input class="oh-input" id="email" name="email" type="email" value="<%= worker.email || '' %>" placeholder="optional" />
    </div>

    <details class="oh-details" <%= worker.bank ? "open" : "" %>>
      <summary>Bank details (optional)</summary>
      <div class="oh-row-2">
        <div class="oh-input-group">
          <label class="oh-label" for="bankAccountHolder">Account holder name</label>
          <input class="oh-input" id="bankAccountHolder" name="bankAccountHolder" value="<%= worker.bank && worker.bank.accountHolderName || '' %>" />
        </div>
        <div class="oh-input-group">
          <label class="oh-label" for="bankAccountNumber">Account number</label>
          <input class="oh-input" id="bankAccountNumber" name="bankAccountNumber" value="<%= worker.bank && worker.bank.accountNumber || '' %>" />
        </div>
      </div>
      <div class="oh-row-2">
        <div class="oh-input-group">
          <label class="oh-label" for="bankIfsc">IFSC</label>
          <input class="oh-input oh-input--code" id="bankIfsc" name="bankIfsc" value="<%= worker.bank && worker.bank.ifsc || '' %>" />
        </div>
        <div class="oh-input-group">
          <label class="oh-label" for="bankName">Bank name</label>
          <input class="oh-input" id="bankName" name="bankName" value="<%= worker.bank && worker.bank.bankName || '' %>" />
        </div>
      </div>
    </details>

    <div class="oh-form-actions">
      <a class="oh-btn oh-btn--small" href="/workers">Cancel</a>
      <button class="oh-btn oh-btn--secondary" type="submit">Save</button>
    </div>
  </form>
</div>

<div class="oh-card oh-form-card oh-form-card--wide" style="margin-top:1rem">
  <h2 class="oh-section-title">Face</h2>
  <% if (worker.photoUrl && worker.faceEncoding && worker.faceEncoding.length) { %>
  <p class="oh-muted">A face is enrolled — this worker can be scanned. Capture again to replace it.</p>
  <% } else { %>
  <p class="oh-muted">No face enrolled yet — this worker can't be scanned for attendance until a face is captured.</p>
  <% } %>
  <form method="post" action="/workers/<%= worker._id %>/face">
    <div class="oh-webcam-wrap">
      <video id="video" class="oh-webcam" autoplay playsinline muted></video>
      <img id="preview" class="oh-shot" src="<%= worker.photoUrl || '' %>" alt="captured photo" <%= worker.photoUrl ? '' : 'hidden' %> />
    </div>
    <canvas id="canvas" hidden></canvas>
    <div class="oh-capture-row">
      <button type="button" class="oh-btn oh-btn--small" id="captureBtn">Capture</button>
      <label class="oh-btn oh-btn--small" for="fileInput">Upload instead</label>
      <input id="fileInput" type="file" accept="image/*" hidden />
      <span id="camNote" class="oh-muted"></span>
    </div>
    <input type="hidden" name="photoData" id="photoData" />
    <div class="oh-form-actions">
      <button class="oh-btn oh-btn--secondary" type="submit" id="submitBtn" disabled>Save face</button>
    </div>
  </form>
</div>

<% if (canDelete && worker.status !== 'deleted') { %>
<div class="oh-card oh-form-card" style="margin-top:1rem;border-color:var(--c-danger)">
  <h2 class="oh-section-title">Delete employee</h2>
  <p class="oh-muted">Soft-delete keeps the record and its history; the employee is hidden from the roster and can no longer clock in. A reason is required.</p>
  <form class="oh-form-inline" method="post" action="/workers/<%= worker._id %>/delete" onsubmit="return confirm('Soft-delete this employee?')">
    <div class="oh-input-group oh-grow">
      <label class="oh-label" for="reason">Reason</label>
      <input class="oh-input" id="reason" name="reason" required placeholder="e.g. left the project" />
    </div>
    <button class="oh-btn oh-btn--danger" type="submit">Delete</button>
  </form>
</div>
<% } %>

<% if (canDelete && worker.status === 'deleted') { %>
<div class="oh-card oh-form-card" style="margin-top:1rem">
  <h2 class="oh-section-title">Restore employee</h2>
  <p class="oh-muted">This employee is archived (deleted). Restoring returns them to active.</p>
  <form method="post" action="/workers/<%= worker._id %>/restore">
    <button class="oh-btn oh-btn--secondary" type="submit">Restore to active</button>
  </form>
</div>
<% } %>

<div class="oh-card oh-form-card" style="margin-top:1rem">
  <h2 class="oh-section-title">Remarks</h2>
  <% if (worker.remarks && worker.remarks.length) { %>
  <table class="oh-table">
    <tbody>
      <% worker.remarks.forEach(function (r, i) { %>
      <tr>
        <td<%= r.cleared ? ' style="text-decoration:line-through;color:var(--c-text-muted)"' : '' %>>
          <span class="oh-badge oh-badge--muted"><%= r.type %></span>
          <%= r.text %>
          <span class="oh-muted">— <%= r.authorName || 'system' %>, <%= r.at ? new Date(r.at).toLocaleString('en-GB', { timeZone: 'Asia/Kolkata', dateStyle: 'medium', timeStyle: 'short' }) : '' %></span>
        </td>
        <td class="oh-col-action">
          <% if (canDelete && !r.cleared) { %>
          <form method="post" action="/workers/<%= worker._id %>/remarks/<%= i %>/clear" style="margin:0">
            <button class="oh-btn oh-btn--small" type="submit">Clear</button>
          </form>
          <% } %>
        </td>
      </tr>
      <% }); %>
    </tbody>
  </table>
  <% } else { %>
  <p class="oh-muted">No remarks yet.</p>
  <% } %>
  <form class="oh-form-inline" method="post" action="/workers/<%= worker._id %>/remarks" style="margin-top:0.75rem">
    <div class="oh-input-group oh-grow">
      <label class="oh-label" for="remarkText">Add a remark</label>
      <input class="oh-input" id="remarkText" name="text" required placeholder="note about this employee" />
    </div>
    <button class="oh-btn oh-btn--secondary" type="submit">Add</button>
  </form>
</div>

<script src="/static/js/enroll.js"></script>
<%- include('../partials/app-bottom') %>
