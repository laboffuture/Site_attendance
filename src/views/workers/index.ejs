<%- include('../partials/app-top', { title: title, active: active }) %>

<div class="oh-page-header oh-page-header--row">
  <div>
    <h1 class="oh-page-title">Workers</h1>
    <p class="oh-page-subtitle">Enrolled daily-wage workers (<%= workers.length %>).</p>
  </div>
  <a class="oh-btn oh-btn--secondary" href="/workers/new">
    <span class="material-icons">person_add</span> Enroll worker
  </a>
</div>

<div class="oh-card">
  <% if (workers.length) { %>
  <table class="oh-table">
    <thead>
      <tr>
        <th></th><th>Reg No</th><th>Name</th><th>Designation</th>
        <th>Site</th><th>Status</th><th class="oh-col-action"></th>
      </tr>
    </thead>
    <tbody>
      <% workers.forEach(function (w) { %>
      <tr>
        <td>
          <% if (w.photoUrl) { %>
          <img class="oh-thumb" src="<%= w.photoUrl %>" alt="" />
          <% } else { %><span class="oh-thumb"></span><% } %>
        </td>
        <td><span class="oh-badge oh-badge--muted"><%= w.empRegNo %></span></td>
        <td><%= w.name %></td>
        <td><%= w.designationName %></td>
        <td><%= w.siteName %></td>
        <td>
          <span class="oh-badge oh-badge--<%= w.status === 'active' ? 'success' : 'muted' %>"><%= w.status %></span>
        </td>
        <td class="oh-col-action">
          <a class="oh-btn oh-btn--small" href="/workers/<%= w._id %>/edit">Edit</a>
        </td>
      </tr>
      <% }); %>
    </tbody>
  </table>
  <% } else { %>
  <p class="oh-muted">No workers enrolled yet. Use “Enroll worker” to add the first.</p>
  <% } %>
</div>

<%- include('../partials/app-bottom') %>
