<%- include('../partials/app-top', { title: title, active: active }) %>

<%- include('../partials/breadcrumb', { back: '/org/branches', trail: [ { label: 'Sites', href: '/org' }, { label: 'Branches', href: '/org/branches' }, { label: 'Edit' } ] }) %>
<div class="oh-page-header">
  <h1 class="oh-page-title">Edit branch</h1>
</div>

<div class="oh-card oh-form-card">
  <form class="oh-form-group" method="post" action="/org/branches/<%= branch._id %>">
    <div class="oh-input-group">
      <label class="oh-label" for="name">Branch name</label>
      <input class="oh-input" id="name" name="name" value="<%= branch.name %>" required />
    </div>
    <div class="oh-form-actions">
      <a class="oh-btn oh-btn--small" href="/org/branches">Cancel</a>
      <button class="oh-btn oh-btn--accent" type="submit">Save</button>
    </div>
  </form>
</div>

<%- include('../partials/app-bottom') %>
