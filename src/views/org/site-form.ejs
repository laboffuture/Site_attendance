<%- include('../partials/app-top', { title: title, active: active }) %>
<%
  var isEdit = mode === 'edit';
  var s = site || {};
  var action = isEdit ? ('/org/sites/' + s._id) : '/org/sites';
  function val(v) { return v == null ? '' : v; }
  var night = (s.shifts && s.shifts.night) || {};
  var polyJson = (s.geofencePolygon && s.geofencePolygon.length) ? JSON.stringify(s.geofencePolygon) : '';
%>
<%- include('../partials/breadcrumb', { back: '/org', trail: [ { label: 'Sites', href: '/org' }, { label: isEdit ? s.name : 'Add Site' } ] }) %>
<div class="oh-page-header oh-page-header--row">
  <div>
    <h1 class="oh-page-title"><%= isEdit ? 'Edit Site' : 'Add Site' %></h1>
    <p class="oh-page-subtitle"><%= isEdit ? (s.code + ' · ' + (s.name || '')) : 'A project location where attendance is captured.' %></p>
  </div>
  <% if (isEdit) { %><a class="oh-btn oh-btn--small oh-btn--secondary oh-only-desktop" href="/org/sites/<%= s._id %>"><span class="material-icons">visibility</span> View</a><% } %>
</div>

<form method="post" action="<%= action %>">
  <div class="oh-card oh-form-card oh-form-card--full">

    <div class="oh-form-section">
      <h3 class="oh-kv-section__title">Identity</h3>
      <div class="oh-frow">
        <label class="oh-frow__label" for="branchId">Branch</label>
        <div class="oh-frow__field">
          <select class="oh-select" id="branchId" name="branchId" required>
            <option value="">— select —</option>
            <% branches.forEach(function (b) { %><option value="<%= b._id %>" <%= isEdit && String(s.branchId) === String(b._id) ? 'selected' : '' %>><%= b.name %></option><% }); %>
          </select>
        </div>
      </div>
      <div class="oh-frow">
        <label class="oh-frow__label" for="name">Site name</label>
        <div class="oh-frow__field"><input class="oh-input" id="name" name="name" value="<%= val(s.name) %>" placeholder="e.g. Anna Nagar Mall" required /></div>
      </div>
      <div class="oh-frow">
        <label class="oh-frow__label" for="code">Site code</label>
        <div class="oh-frow__field"><input class="oh-input oh-input--code" id="code" name="code" value="<%= val(s.code) %>" placeholder="e.g. ANM" required /></div>
      </div>
    </div>

    <div class="oh-form-section">
      <h3 class="oh-kv-section__title">Shifts &amp; overtime</h3>
      <div class="oh-frow">
        <label class="oh-frow__label">Day shift <span class="oh-muted">(start – end)</span></label>
        <div class="oh-frow__field oh-frow__pair">
          <input class="oh-input oh-time24" name="standardStartTime" type="text" inputmode="numeric" placeholder="HH:MM" pattern="([01][0-9]|2[0-3]):[0-5][0-9]" maxlength="5" aria-label="Day shift start" value="<%= s.standardStartTime || '09:00' %>" required />
          <input class="oh-input oh-time24" name="standardEndTime" type="text" inputmode="numeric" placeholder="HH:MM" pattern="([01][0-9]|2[0-3]):[0-5][0-9]" maxlength="5" aria-label="Day shift end" value="<%= s.standardEndTime || '18:00' %>" required />
        </div>
      </div>
      <div class="oh-frow">
        <label class="oh-frow__label">Night shift</label>
        <div class="oh-frow__field">
          <label class="oh-check"><input type="checkbox" name="nightShiftEnabled" id="nightShiftEnabled" <%= s.nightShiftEnabled ? 'checked' : '' %> /> This site runs a night shift</label>
          <div class="oh-frow__pair" style="margin-top:0.5rem">
            <input class="oh-input oh-time24" name="nightStartTime" type="text" inputmode="numeric" placeholder="HH:MM" pattern="([01][0-9]|2[0-3]):[0-5][0-9]" maxlength="5" aria-label="Night shift start" value="<%= night.startTime || '' %>" />
            <input class="oh-input oh-time24" name="nightEndTime" type="text" inputmode="numeric" placeholder="HH:MM" pattern="([01][0-9]|2[0-3]):[0-5][0-9]" maxlength="5" aria-label="Night shift end" value="<%= night.endTime || '' %>" />
          </div>
        </div>
      </div>
      <div class="oh-frow">
        <label class="oh-frow__label" for="allowedOtHours">Allowed OT hours / day <span class="oh-muted">(optional)</span></label>
        <div class="oh-frow__field"><input class="oh-input" id="allowedOtHours" name="allowedOtHours" type="number" min="0" max="24" step="0.5" value="<%= s.allowedOtHours != null ? s.allowedOtHours : '' %>" placeholder="e.g. 4" style="max-width:160px" /></div>
      </div>
      <div class="oh-frow">
        <label class="oh-frow__label" for="lunchHours">Lunch deduction / day <span class="oh-muted">(payroll, hours)</span></label>
        <div class="oh-frow__field"><input class="oh-input" id="lunchHours" name="lunchHours" type="number" min="0" max="8" step="0.5" value="<%= s.lunchHours != null ? s.lunchHours : 1 %>" placeholder="1" style="max-width:160px" /><span class="oh-field-hint">Subtracted from each day's worked hours before normal/OT are split.</span></div>
      </div>
    </div>

    <div class="oh-form-section">
      <h3 class="oh-kv-section__title">Coverage area &amp; geofence</h3>
      <div class="oh-frow">
        <label class="oh-frow__label">Coverage area<span class="oh-muted">Search, drop a pin, or draw the boundary. When set, scans are checked against it.</span></label>
        <div class="oh-frow__field">
          <div class="oh-map-search">
            <input class="oh-input" id="site-map-search" type="text" placeholder="Search address / place (e.g. Vadapalani, Chennai)" />
            <button class="oh-btn oh-btn--small" type="button" id="site-map-search-btn">Search</button>
          </div>
          <div class="oh-map-tools">
            <button class="oh-btn oh-btn--small" type="button" id="map-draw-circle"><span class="material-icons">radio_button_unchecked</span> Draw circle</button>
            <button class="oh-btn oh-btn--small" type="button" id="map-draw-rect"><span class="material-icons">crop_square</span> Draw rectangle</button>
            <button class="oh-btn oh-btn--small" type="button" id="map-my-location"><span class="material-icons">my_location</span> My location</button>
            <button class="oh-btn oh-btn--small" type="button" id="map-clear"><span class="material-icons">close</span> Clear</button>
          </div>
          <div id="site-map" class="oh-map"></div>
          <input type="hidden" name="geofencePolygon" value="<%= polyJson %>" />
        </div>
      </div>
      <div class="oh-frow">
        <label class="oh-frow__label">Coordinates</label>
        <div class="oh-frow__field oh-frow__pair">
          <input class="oh-input" name="latitude" aria-label="Latitude" value="<%= s.latitude != null ? s.latitude : '' %>" placeholder="Latitude (13.0405)" />
          <input class="oh-input" name="longitude" aria-label="Longitude" value="<%= s.longitude != null ? s.longitude : '' %>" placeholder="Longitude (80.2337)" />
        </div>
      </div>
      <div class="oh-frow">
        <label class="oh-frow__label" for="geofenceRadiusMeters">Geofence radius <span class="oh-muted">(circle, metres)</span></label>
        <div class="oh-frow__field"><input class="oh-input" id="geofenceRadiusMeters" name="geofenceRadiusMeters" type="number" min="1" value="<%= s.geofenceRadiusMeters != null ? s.geofenceRadiusMeters : '' %>" placeholder="e.g. 150" style="max-width:160px" /></div>
      </div>
    </div>

    <div class="oh-form-section">
      <h3 class="oh-kv-section__title">Profile</h3>
      <div class="oh-frow">
        <label class="oh-frow__label" for="address">Address <span class="oh-muted">(optional)</span></label>
        <div class="oh-frow__field"><input class="oh-input" id="address" name="address" value="<%= val(s.address) %>" placeholder="street, area" /></div>
      </div>
      <div class="oh-frow">
        <label class="oh-frow__label" for="inChargeName">In-charge</label>
        <div class="oh-frow__field oh-frow__pair">
          <input class="oh-input" id="inChargeName" name="inChargeName" value="<%= val(s.inChargeName) %>" list="incharge-list" placeholder="name" />
          <input class="oh-input" id="inChargePhone" name="inChargePhone" type="tel" value="<%= val(s.inChargePhone) %>" placeholder="+91… phone" />
        </div>
      </div>
      <div class="oh-frow">
        <label class="oh-frow__label" for="clientName">Client / project <span class="oh-muted">(optional)</span></label>
        <div class="oh-frow__field"><input class="oh-input" id="clientName" name="clientName" value="<%= val(s.clientName) %>" placeholder="optional" /></div>
      </div>
    </div>

    <div class="oh-form-actions">
      <a class="oh-btn oh-btn--small" href="/org">Cancel</a>
      <button class="oh-btn oh-btn--accent" type="submit"><%= isEdit ? 'Save site' : 'Add site' %></button>
    </div>
  </div>
</form>

<datalist id="incharge-list"><% (inCharges || []).forEach(function (n) { %><option value="<%= n %>"></option><% }); %></datalist>
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/leaflet.draw/1.0.4/leaflet.draw.css" />
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/leaflet.draw/1.0.4/leaflet.draw.js"></script>
<script src="/static/js/site-map.js"></script>

<%- include('../partials/app-bottom') %>
