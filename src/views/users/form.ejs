<%- include('../partials/app-top', { title: title, active: active }) %>
<%
  var isEdit = mode === "edit";
  var u = user || {};
  var assigned = (u.assignedSiteIds || []).map(function (x) { return String(x); });
  var self = typeof isSelf !== "undefined" && isSelf;
%>
<%- include('../partials/breadcrumb', { back: '/users', trail: [ { label: 'Users & Roles', href: '/users' }, { label: isEdit ? u.name : 'Add User' } ] }) %>
<div class="oh-page-header oh-page-header--row">
  <div>
    <h1 class="oh-page-title"><%= isEdit ? 'Edit User' : 'Add User' %></h1>
    <p class="oh-page-subtitle"><%= self ? 'This is your account — role and status are locked to prevent lockout.' : 'A staff account with login access.' %></p>
  </div>
  <% if (isEdit) { %><a class="oh-btn oh-btn--small oh-btn--secondary oh-only-desktop" href="/users/<%= u._id %>"><span class="material-icons">visibility</span> View</a><% } %>
</div>

<form method="post" action="<%= isEdit ? '/users/' + u._id : '/users' %>">
  <div class="oh-card oh-form-card oh-form-card--full">

    <div class="oh-form-section">
      <h3 class="oh-kv-section__title">Identity</h3>
      <div class="oh-frow"><label class="oh-frow__label" for="name">Name</label><div class="oh-frow__field"><input class="oh-input" id="name" name="name" value="<%= u.name || '' %>" required /></div></div>
      <div class="oh-frow"><label class="oh-frow__label" for="email">Email</label><div class="oh-frow__field"><input class="oh-input" id="email" type="email" name="email" value="<%= u.email || '' %>" required /></div></div>
      <div class="oh-frow"><label class="oh-frow__label" for="phone">Phone <span class="oh-muted">(optional)</span></label><div class="oh-frow__field"><input class="oh-input" id="phone" type="tel" name="phone" value="<%= u.phone || '' %>" placeholder="e.g. +91 90000 00000" /></div></div>
    </div>

    <div class="oh-form-section">
      <h3 class="oh-kv-section__title">Access</h3>
      <div class="oh-frow">
        <label class="oh-frow__label" for="role">Role</label>
        <div class="oh-frow__field">
          <select class="oh-select" id="role" name="role" <%= self ? 'disabled' : '' %> required>
            <% roles.forEach(function (rn) { %><option value="<%= rn %>" <%= u.role === rn ? 'selected' : '' %>><%= roleLabel(rn) %></option><% }); %>
          </select>
          <% if (self) { %><span class="oh-muted">You can't change your own role.</span><% } %>
        </div>
      </div>
      <div class="oh-frow">
        <label class="oh-frow__label" for="password">Password</label>
        <div class="oh-frow__field"><input class="oh-input" id="password" type="password" name="password" <%= isEdit ? '' : 'required' %> placeholder="<%= isEdit ? 'leave blank to keep current' : 'set a password' %>" /></div>
      </div>
      <% if (isEdit && !self) { %>
      <div class="oh-frow">
        <label class="oh-frow__label">Status</label>
        <div class="oh-frow__field"><label class="oh-check"><input type="checkbox" name="active" <%= u.active ? 'checked' : '' %> /> Active (can log in)</label></div>
      </div>
      <% } %>
    </div>

    <div class="oh-form-section">
      <h3 class="oh-kv-section__title">Permissions <span class="oh-muted" style="text-transform:none;letter-spacing:0;font-weight:400">— starts from the role's defaults; tick to customise. You can only grant permissions you hold.</span></h3>
      <div class="oh-perm">
        <% permGroups.forEach(function (g) { %>
        <div class="oh-perm__group">
          <div class="oh-perm__gtitle"><%= g.group %></div>
          <% g.caps.forEach(function (c) { var on = checkedCaps.indexOf(c.cap) >= 0; var canGrant = grantable.indexOf(c.cap) >= 0; %>
          <label class="oh-perm__check <%= canGrant ? '' : 'is-locked' %>" title="<%= canGrant ? '' : 'You do not hold this permission, so you cannot grant it.' %>">
            <input type="checkbox" name="capabilities" value="<%= c.cap %>" data-cap <%= on ? 'checked' : '' %> <%= canGrant ? '' : 'disabled' %> />
            <span><%= c.label %></span>
          </label>
          <% }); %>
        </div>
        <% }); %>
      </div>
    </div>

    <div class="oh-form-section">
      <h3 class="oh-kv-section__title">Site scope</h3>
      <div class="oh-frow">
        <label class="oh-frow__label" for="assignedSiteIds">Assigned sites<span class="oh-muted">PM / Supervisor only. Management & HR see all sites.</span></label>
        <div class="oh-frow__field">
          <select class="oh-select" id="assignedSiteIds" name="assignedSiteIds" multiple size="6">
            <% sites.forEach(function (s) { %><option value="<%= s._id %>" <%= assigned.indexOf(String(s._id)) >= 0 ? 'selected' : '' %>><%= s.name %> (<%= s.code %>)</option><% }); %>
          </select>
        </div>
      </div>
    </div>

    <div class="oh-form-actions">
      <a class="oh-btn oh-btn--small" href="/users">Cancel</a>
      <button class="oh-btn oh-btn--accent" type="submit"><%= isEdit ? 'Save user' : 'Create user' %></button>
    </div>
  </div>
</form>

<script>
  // Changing the role resets the permission checkboxes to that role's defaults
  // (a starting point), and re-computes which are grantable: a cap is grantable
  // if it's in the role's defaults OR the admin personally holds it.
  (function () {
    var sel = document.getElementById('role');
    var defaults = <%- JSON.stringify(roleDefaults) %>;
    var actorCaps = <%- JSON.stringify(actorCaps) %>;
    var boxes = document.querySelectorAll('input[data-cap]');
    if (!sel || !boxes.length) return;
    sel.addEventListener('change', function () {
      var def = defaults[sel.value] || [];
      boxes.forEach(function (b) {
        var grant = def.indexOf(b.value) >= 0 || actorCaps.indexOf(b.value) >= 0;
        b.disabled = !grant;
        var lab = b.closest('.oh-perm__check');
        if (lab) lab.classList.toggle('is-locked', !grant);
        b.checked = grant && def.indexOf(b.value) >= 0;
      });
    });
  })();
</script>

<%- include('../partials/app-bottom') %>
