<%- include('../partials/app-top', { title: title, active: active }) %>

<%- include('../partials/breadcrumb', { back: '/designations', trail: [ { label: 'Designations', href: '/designations' }, { label: designation.name }, { label: 'Rename' } ] }) %>
<div class="oh-page-header">
  <h1 class="oh-page-title">Rename designation</h1>
</div>

<div class="oh-card oh-form-card">
  <form class="oh-form-group" method="post" action="/designations/<%= designation._id %>">
    <div class="oh-input-group">
      <label class="oh-label" for="name">Designation name</label>
      <input class="oh-input" id="name" name="name" value="<%= designation.name %>" required />
    </div>
    <div class="oh-form-actions">
      <a class="oh-btn oh-btn--small" href="/designations">Cancel</a>
      <button class="oh-btn oh-btn--accent" type="submit">Save</button>
    </div>
  </form>
</div>

<%- include('../partials/app-bottom') %>
