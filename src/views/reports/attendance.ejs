<%- include('../partials/app-top', { title: title, active: active }) %>
<%
  var badgeFor = { pending: "warning", approved: "success", rejected: "danger", none: "muted" };
  var statusText = { none: "—", pending: "Pending", approved: "Approved", rejected: "Rejected" };
  function otClass(s) { return s === "approved" ? "oh-ot-approved" : (s === "pending" ? "oh-ot-pending" : ""); }
%>
<%- include('../partials/breadcrumb', { back: '/reports', trail: [ { label: 'Reports', href: '/reports' }, { label: 'Attendance' } ] }) %>
<div class="oh-page-header oh-page-header--row">
  <div>
    <h1 class="oh-page-title">Attendance report</h1>
    <p class="oh-page-subtitle">Grouped by branch → site · <span class="oh-muted"><%= activeFilter %></span></p>
  </div>
  <div class="oh-actions">
    <a class="oh-btn oh-btn--small oh-btn--secondary" href="/reports/attendance/export.xlsx<%= query %>"><span class="material-icons">download</span> Excel</a>
    <a class="oh-btn oh-btn--small oh-btn--secondary" href="/reports/attendance/export.pdf<%= query %>"><span class="material-icons">picture_as_pdf</span> PDF</a>
  </div>
</div>

<% if (capped) { %>
<div class="oh-alert oh-alert--warning">Showing the first <%= shown.toLocaleString('en-IN') %> of <strong><%= rowCount.toLocaleString('en-IN') %></strong> matching rows in the table below — the summary tiles and charts cover the <em>full</em> set. Narrow the filters (or export) for a complete row list.</div>
<% } %>

<% if (absence.skipped) { %>
<div class="oh-alert oh-alert--info">Absent employees aren't included yet — pick a <strong>From</strong> and <strong>To</strong> date (up to <%= absence.maxSpanDays %> days) to also see who didn't clock in on each day.</div>
<% } else if (absence.capped) { %>
<div class="oh-alert oh-alert--warning">The absent-employee list is very large for this range and was capped — narrow the filters (site, designation, or a shorter date range) for a complete count.</div>
<% } %>

<div class="oh-statstrip">
  <div class="oh-statstrip__item"><span class="oh-statstrip__num"><%= summary.records.toLocaleString('en-IN') %></span><span class="oh-statstrip__label">Present records</span></div>
  <% if (!absence.skipped) { %>
  <div class="oh-statstrip__item"><span class="oh-statstrip__num <%= summary.absent ? 'is-warn' : '' %>"><%= summary.absent.toLocaleString('en-IN') %></span><span class="oh-statstrip__label">Absent</span></div>
  <% } %>
  <div class="oh-statstrip__item"><span class="oh-statstrip__num"><%= summary.employees %></span><span class="oh-statstrip__label">Employees</span></div>
  <div class="oh-statstrip__item"><span class="oh-statstrip__num"><%= summary.otHours %></span><span class="oh-statstrip__label">OT hours</span></div>
  <div class="oh-statstrip__item"><span class="oh-statstrip__num"><%= summary.sites %></span><span class="oh-statstrip__label">Sites</span></div>
</div>

<div class="oh-card oh-stack">
  <form class="oh-form-inline" method="get" action="/reports/attendance">
    <div class="oh-input-group"><label class="oh-label" for="dateFrom">From</label><input class="oh-input" id="dateFrom" type="date" name="dateFrom" value="<%= filters.dateFrom || '' %>" /></div>
    <div class="oh-input-group"><label class="oh-label" for="dateTo">To</label><input class="oh-input" id="dateTo" type="date" name="dateTo" value="<%= filters.dateTo || '' %>" /></div>
    <div class="oh-input-group">
      <label class="oh-label" for="siteId">Site</label>
      <select class="oh-select" id="siteId" name="siteId"><option value="">All sites</option>
        <% sites.forEach(function (s) { %><option value="<%= s._id %>" <%= String(filters.siteId) === String(s._id) ? "selected" : "" %>><%= s.name %> (<%= s.code %>)</option><% }); %>
      </select>
    </div>
    <div class="oh-input-group">
      <label class="oh-label" for="designation">Designation</label>
      <select class="oh-select" id="designation" name="designation"><option value="">All</option>
        <% designations.forEach(function (d) { %><option value="<%= d.name %>" <%= filters.designation === d.name ? "selected" : "" %>><%= d.name %></option><% }); %>
      </select>
    </div>
    <div class="oh-input-group oh-grow"><label class="oh-label" for="q">Worker</label><input class="oh-input" id="q" name="q" placeholder="name or reg no" value="<%= filters.q || '' %>" /></div>
    <button class="oh-btn oh-btn--secondary" type="submit">Filter</button>
    <a class="oh-btn oh-btn--small" href="/reports/attendance">Reset</a>
  </form>
</div>

<% if (rowCount > 0) { %>
<div class="oh-chart-grid">
  <div class="oh-card"><div class="oh-card__label">Attendance by day</div><div class="oh-rpt-chart" id="rpt-byday"></div></div>
  <div class="oh-card"><div class="oh-card__label">Records by site</div><div class="oh-rpt-chart" id="rpt-bysite"></div></div>
  <div class="oh-card"><div class="oh-card__label">OT hours by site</div><div class="oh-rpt-chart" id="rpt-otsite"></div></div>
</div>
<% } %>

<% if (groups.length) { %>
<% groups.forEach(function (b) { %>
<div class="oh-card oh-stack">
  <div class="oh-section-header"><span class="oh-section-title"><%= b.branchName %></span></div>
  <% b.sites.forEach(function (s) { %>
  <div>
    <div class="oh-report-site"><%= s.siteName %> · <%= s.rows.length %> record(s)</div>
    <div class="oh-only-mobile oh-m-list">
      <% s.rows.forEach(function (r) { var h = hoursBreakdown(r); var isAbsent = r.inTime == null; %>
      <div class="oh-m-card">
        <div class="oh-m-row" style="justify-content:space-between;align-items:flex-start;">
          <span class="oh-m-grow"><span class="oh-m-name"><%= r.workerName %><% if (r.source === "manual") { %> <span class="oh-m-badge oh-badge--warning">M</span><% } %></span><span class="oh-m-sub"><%= r.empRegNo %> · <%= r.designationName %></span></span>
          <span class="oh-m-sub"><%= r.date %></span>
        </div>
        <div style="margin-top:0.4rem;"><span class="oh-m-badge oh-badge--<%= isAbsent ? 'danger' : 'success' %>"><%= isAbsent ? 'Absent' : 'Present' %></span></div>
        <% if (!isAbsent) { %>
        <div class="oh-m-boxes" style="margin-top:0.6rem;">
          <div class="oh-m-box"><div class="oh-m-box__k">Standard</div><div class="oh-m-box__v"><%= h.worked != null ? h.standard + "h" : "—" %></div></div>
          <div class="oh-m-box"><div class="oh-m-box__k">OT</div><div class="oh-m-box__v <%= otClass(h.otStatus) %>"><%= h.otComputed > 0 ? h.otComputed + "h" : "—" %></div></div>
          <div class="oh-m-box"><div class="oh-m-box__k">Total</div><div class="oh-m-box__v"><%= h.payableTotal != null ? h.payableTotal + "h" : "—" %></div></div>
        </div>
        <div style="margin-top:0.5rem;display:flex;align-items:center;gap:8px;">
          <span class="oh-m-badge oh-badge--<%= badgeFor[h.otStatus] %>"><%= statusText[h.otStatus] || h.otStatus %></span>
          <% if (h.otStatus === "pending" && h.otComputed > 0) { %><span class="oh-m-sub oh-ot-pending">+<%= h.otComputed %>h pending</span><% } %>
        </div>
        <% } %>
      </div>
      <% }); %>
    </div>
    <table class="oh-table oh-only-desktop">
      <thead><tr><th>Date</th><th>Reg No</th><th>Name</th><th>Designation</th><th>Attendance</th><th>Standard</th><th>OT</th><th>Total</th><th>OT Status</th><th>Location</th></tr></thead>
      <tbody>
        <% s.rows.forEach(function (r) { var h = hoursBreakdown(r); var isAbsent = r.inTime == null; %>
        <tr<% if (isAbsent) { %> class="oh-row-absent"<% } %>>
          <td><%= r.date %></td>
          <td><%= r.empRegNo %></td>
          <td><%= r.workerName %><% if (r.source === "manual") { %> <span class="oh-badge oh-badge--warning" title="Marked manually">M</span><% } %></td>
          <td><%= r.designationName %></td>
          <td><span class="oh-badge oh-badge--<%= isAbsent ? 'danger' : 'success' %>"><%= isAbsent ? 'Absent' : 'Present' %></span></td>
          <% if (isAbsent) { %>
          <td colspan="4" class="oh-muted">—</td>
          <% } else { %>
          <td><%= h.worked != null ? h.standard + "h" : "—" %></td>
          <td><% if (h.otComputed > 0) { %><span class="<%= otClass(h.otStatus) %>"><%= h.otComputed %>h</span><% } else { %>—<% } %></td>
          <td><strong><%= h.payableTotal != null ? h.payableTotal + "h" : "—" %></strong><% if (h.otStatus === "pending" && h.otComputed > 0) { %><br /><span class="oh-muted oh-ot-pending">+<%= h.otComputed %>h pending</span><% } %></td>
          <td><span class="oh-badge oh-badge--<%= badgeFor[h.otStatus] %>"><%= statusText[h.otStatus] || h.otStatus %></span></td>
          <% } %>
          <td>
            <% var g = r.inGeo; if (g && g.available && g.lat != null) { %>
            <a href="https://maps.google.com/?q=<%= g.lat %>,<%= g.lng %>" target="_blank" rel="noopener" title="In-scan location"><span class="material-icons" style="font-size:0.95rem;vertical-align:middle">place</span><%= g.distanceMeters != null ? " " + g.distanceMeters + "m" : "" %></a>
            <% } else { %><span class="oh-muted">—</span><% } %>
          </td>
        </tr>
        <% }); %>
      </tbody>
    </table>
  </div>
  <% }); %>
</div>
<% }); %>
<% } else { %>
<div class="oh-empty"><span class="material-icons">fact_check</span><p>No attendance records match these filters.</p></div>
<% } %>

<% if (rowCount > 0) { %>
<script>window.__REPORT_CHARTS__ = <%- JSON.stringify(reportCharts) %>;</script>
<script src="https://cdn.jsdelivr.net/npm/apexcharts@3.54.1/dist/apexcharts.min.js"></script>
<script src="/static/js/report-charts.js"></script>
<% } %>

<%- include('../partials/app-bottom') %>
