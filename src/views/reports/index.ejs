<%- include('../partials/app-top', { title: title, active: active }) %>

<div class="oh-page-header oh-page-header--row">
  <div>
    <h1 class="oh-page-title">Reports</h1>
    <p class="oh-page-subtitle">Workforce, attendance and overtime analytics — with exports.</p>
  </div>
</div>

<div class="oh-report-grid">
  <% reports.forEach(function (r) { %>
  <a class="oh-report-card" href="<%= r.href %>">
    <div class="oh-report-card__top">
      <span class="oh-report-card__icon material-icons"><%= r.icon %></span>
      <span class="oh-report-card__title"><%= r.title %></span>
    </div>
    <div class="oh-report-card__metric"><%= r.metric %> <small><%= r.unit %></small></div>
    <div class="oh-report-card__sub"><%= r.sub %></div>
    <div class="oh-report-card__desc"><%= r.desc %></div>
    <span class="oh-report-card__cta">Open report <span class="material-icons">arrow_forward</span></span>
  </a>
  <% }); %>

  <div class="oh-report-card is-soon" aria-disabled="true">
    <div class="oh-report-card__top">
      <span class="oh-report-card__icon material-icons">inventory_2</span>
      <span class="oh-report-card__title">Asset &amp; Allocation</span>
    </div>
    <div class="oh-report-card__metric">—</div>
    <div class="oh-report-card__sub">Arrives with the Assets / Manpower-allocation modules</div>
    <div class="oh-report-card__desc">Asset registers and resource-allocation reports.</div>
    <span class="oh-report-card__cta"><span class="oh-badge oh-badge--muted">Coming soon</span></span>
  </div>
</div>

<%- include('../partials/app-bottom') %>
