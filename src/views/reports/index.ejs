<%- include('../partials/app-top', { title: title, active: active }) %>
<%
  function t(d) { return d ? new Date(d).toLocaleTimeString("en-GB", { timeZone: "Asia/Kolkata", hour: "2-digit", minute: "2-digit" }) : "—"; }
  var badgeFor = { pending: "warning", approved: "success", rejected: "danger", none: "muted" };
%>

<div class="oh-page-header oh-page-header--row">
  <div>
    <h1 class="oh-page-title">Reports</h1>
    <p class="oh-page-subtitle">Attendance, grouped by branch → site. Showing <%= rowCount %><%= rowCount >= maxRows ? " (capped)" : "" %> rows.</p>
  </div>
  <div class="oh-form-actions">
    <a class="oh-btn oh-btn--small" href="/reports/export.xlsx<%= query %>">Export Excel</a>
    <a class="oh-btn oh-btn--small" href="/reports/export.pdf<%= query %>">Export PDF</a>
  </div>
</div>

<div class="oh-card oh-stack">
  <form class="oh-form-inline" method="get" action="/reports">
    <div class="oh-input-group">
      <label class="oh-label" for="dateFrom">From</label>
      <input class="oh-input" id="dateFrom" type="date" name="dateFrom" value="<%= filters.dateFrom || '' %>" />
    </div>
    <div class="oh-input-group">
      <label class="oh-label" for="dateTo">To</label>
      <input class="oh-input" id="dateTo" type="date" name="dateTo" value="<%= filters.dateTo || '' %>" />
    </div>
    <div class="oh-input-group">
      <label class="oh-label" for="siteId">Site</label>
      <select class="oh-select" id="siteId" name="siteId">
        <option value="">All sites</option>
        <% sites.forEach(function (s) { %>
        <option value="<%= s._id %>" <%= String(filters.siteId) === String(s._id) ? "selected" : "" %>><%= s.name %> (<%= s.code %>)</option>
        <% }); %>
      </select>
    </div>
    <div class="oh-input-group">
      <label class="oh-label" for="designation">Designation</label>
      <select class="oh-select" id="designation" name="designation">
        <option value="">All</option>
        <% designations.forEach(function (d) { %>
        <option value="<%= d.name %>" <%= filters.designation === d.name ? "selected" : "" %>><%= d.name %></option>
        <% }); %>
      </select>
    </div>
    <div class="oh-input-group oh-grow">
      <label class="oh-label" for="q">Worker</label>
      <input class="oh-input" id="q" name="q" placeholder="name or reg no" value="<%= filters.q || '' %>" />
    </div>
    <button class="oh-btn oh-btn--secondary" type="submit">Filter</button>
    <a class="oh-btn oh-btn--small" href="/reports">Reset</a>
  </form>
</div>

<% if (groups.length) { %>
<% groups.forEach(function (b) { %>
<div class="oh-card oh-stack">
  <div class="oh-section-header"><span class="oh-section-title"><%= b.branchName %></span></div>
  <% b.sites.forEach(function (s) { %>
  <div>
    <div class="oh-report-site"><%= s.siteName %> · <%= s.rows.length %> record(s)</div>
    <table class="oh-table">
      <thead>
        <tr><th>Date</th><th>Reg No</th><th>Name</th><th>Designation</th><th>In</th><th>Out</th><th>Total</th><th>OT</th><th>Status</th><th>Location</th></tr>
      </thead>
      <tbody>
        <% s.rows.forEach(function (r) { %>
        <tr>
          <td><%= r.date %></td>
          <td><%= r.empRegNo %></td>
          <td>
            <%= r.workerName %>
            <% if (r.source === "manual") { %><span class="oh-badge oh-badge--warning" title="Marked manually">M</span><% } %>
          </td>
          <td><%= r.designationName %></td>
          <td><%= t(r.inTime) %></td>
          <td><%= t(r.outTime) %></td>
          <td><%= r.totalHours != null ? r.totalHours + "h" : "—" %></td>
          <td><%= (r.overtime && r.overtime.computedHours) || 0 %>h</td>
          <td><span class="oh-badge oh-badge--<%= badgeFor[(r.overtime && r.overtime.status) || 'none'] %>"><%= (r.overtime && r.overtime.status) || "none" %></span></td>
          <td>
            <% var g = r.inGeo; %>
            <% if (g && g.available && g.lat != null) { %>
            <a href="https://maps.google.com/?q=<%= g.lat %>,<%= g.lng %>" target="_blank" rel="noopener" title="In-scan location">📍<%= g.distanceMeters != null ? " " + g.distanceMeters + "m" : "" %></a>
            <% } else if (g && !g.available) { %>
            <span class="oh-muted" title="No GPS captured">—</span>
            <% } else { %>
            <span class="oh-muted">—</span>
            <% } %>
          </td>
        </tr>
        <% }); %>
      </tbody>
    </table>
  </div>
  <% }); %>
</div>
<% }); %>
<% } else { %>
<div class="oh-card"><p class="oh-muted">No attendance records match these filters.</p></div>
<% } %>

<%- include('../partials/app-bottom') %>
