<%- include('../partials/app-top', { title: title, active: active }) %>

<div class="oh-page-header oh-page-header--row">
  <div>
    <h1 class="oh-page-title">Reports</h1>
    <p class="oh-page-subtitle">Workforce, attendance and overtime analytics — with exports.</p>
  </div>
</div>

<div class="oh-action-cards">
  <% reports.forEach(function (r) { %>
  <a class="oh-action-card" href="<%= r.href %>">
    <span class="oh-action-card__icon material-icons"><%= r.icon %></span>
    <span class="oh-action-card__text">
      <span class="oh-action-card__title"><%= r.title %></span>
      <span class="oh-action-card__desc"><%= r.desc %></span>
    </span>
  </a>
  <% }); %>
  <div class="oh-action-card is-soon" aria-disabled="true">
    <span class="oh-action-card__icon material-icons">inventory_2</span>
    <span class="oh-action-card__text">
      <span class="oh-action-card__title">Asset &amp; Allocation reports <span class="oh-badge oh-badge--muted">soon</span></span>
      <span class="oh-action-card__desc">Arrive with the Assets / Manpower-allocation modules.</span>
    </span>
  </div>
</div>

<%- include('../partials/app-bottom') %>
