<%
  // Buttons available for this request, by role + status.
  // PM recommends a pending request; admins approve a recommended one or
  // reject from pending/recommended. No withdraw action exists.
%>
<div class="oh-req-actions">
  <% if (canRecommend && r.status === "pending") { %>
  <form method="post" action="/requests/<%= r._id %>/recommend"><button class="oh-btn oh-btn--small oh-btn--secondary" type="submit">Recommend</button></form>
  <% } %>
  <% if (canDecide && r.status === "recommended") { %>
  <form method="post" action="/requests/<%= r._id %>/approve"><button class="oh-btn oh-btn--small oh-btn--success" type="submit">Approve</button></form>
  <% } %>
  <% if (canDecide && (r.status === "pending" || r.status === "recommended")) { %>
  <form method="post" action="/requests/<%= r._id %>/reject"><button class="oh-btn oh-btn--small oh-btn--danger" type="submit">Reject</button></form>
  <% } %>
  <% if (r.status === "approved" || r.status === "rejected") { %>
  <span class="oh-muted">by <%= r.decidedByName || "—" %></span>
  <% } else if (!canRecommend && !canDecide) { %>
  <span class="oh-muted">awaiting review</span>
  <% } %>
</div>
