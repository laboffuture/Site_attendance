<%- include('../partials/app-top', { title: title, active: active }) %>
<%
  function ts(d) { return d ? new Date(d).toLocaleString("en-GB", { timeZone: "Asia/Kolkata", dateStyle: "medium", timeStyle: "short" }) : ""; }
  var dot = { pending: "var(--c-warning)", recommended: "var(--c-accent)", approved: "var(--c-success)", rejected: "var(--c-danger)" };
  var statusBadge = { pending: "warning", recommended: "info", approved: "success", rejected: "danger" };
  var typeLabel = { scheduled_ot: "Scheduled OT", offload: "Offload" };
  var bands = [
    { key: "pending", label: "Pending", n: counts.pending, cls: "oh-qband__item--warn" },
    { key: "recommended", label: "Recommended", n: counts.recommended, cls: "" },
    { key: "decided", label: "Decided", n: counts.decided, cls: "oh-qband__item--ok" },
    { key: "all", label: "All", n: counts.pending + counts.recommended + counts.decided, cls: "" },
  ];
%>

<div class="oh-page-header oh-page-header--row">
  <div>
    <h1 class="oh-page-title">Requests</h1>
    <p class="oh-page-subtitle">Scheduled overtime &amp; offload suggestions. PM recommends → admin approves. Requests can't be withdrawn.</p>
  </div>
  <% if (canCreate) { %><a class="oh-btn oh-btn--accent oh-only-desktop" href="/requests/new"><span class="material-icons">add</span> New request</a><% } %>
</div>

<div class="oh-qband">
  <% bands.forEach(function (b) { %>
  <a class="oh-qband__item <%= b.cls %> <%= tab === b.key ? 'is-active' : '' %>" href="/requests?tab=<%= b.key %>">
    <span class="oh-qband__num"><%= b.n %></span>
    <span class="oh-qband__label"><%= b.label %></span>
  </a>
  <% }); %>
</div>

<% if (!requests.length) { %>
<div class="oh-empty"><span class="material-icons">assignment</span><p>No <%= tab === "all" ? "" : tab %> requests.</p></div>
<% } else { %>

<!-- mobile cards -->
<div class="oh-only-mobile oh-m-list">
  <% requests.forEach(function (r) { %>
  <div class="oh-m-card" style="border-left:3px solid <%= dot[r.status] || 'var(--c-border)' %>">
    <div class="oh-m-row" style="justify-content:space-between;">
      <span class="oh-m-badge oh-badge--muted"><%= typeLabel[r.type] || r.type %></span>
      <span class="oh-m-badge oh-badge--<%= statusBadge[r.status] %>"><%= r.status %></span>
    </div>
    <div class="oh-m-name" style="margin-top:0.4rem;"><%= r.workerName %> <span class="oh-muted">(<%= r.empRegNo %>)</span></div>
    <div class="oh-m-sub"><%= r.siteName %></div>
    <% if (r.type === "scheduled_ot") { %><div class="oh-m-sub"><%= r.date %> · <%= r.fromTime %>–<%= r.toTime %> (<%= r.hours %>h)</div><% } %>
    <% if (r.requesterRemarks) { %><div class="oh-m-sub">“<%= r.requesterRemarks %>” — <%= r.requestedByName %></div><% } %>
    <%- include('actions', { r: r, canRecommend: canRecommend, canDecide: canDecide }) %>
  </div>
  <% }); %>
</div>

<!-- desktop ledger -->
<div class="oh-card oh-card--flush oh-only-desktop">
  <table class="oh-people">
    <thead><tr><th class="oh-people__spinecol"></th><th>Type</th><th>Worker</th><th>Site</th><th>Details</th><th>Requested by</th><th>Status</th><th class="oh-people__actcol">Action</th></tr></thead>
    <tbody>
      <% requests.forEach(function (r) { %>
      <tr style="--spine: <%= dot[r.status] || 'var(--c-border)' %>">
        <td class="oh-people__spine"></td>
        <td><span class="oh-badge oh-badge--muted"><%= typeLabel[r.type] || r.type %></span></td>
        <td><span class="oh-person__txt"><span class="oh-person__name"><%= r.workerName %></span><span class="oh-person__id"><%= r.empRegNo %></span></span></td>
        <td><%= r.siteName %></td>
        <td>
          <% if (r.type === "scheduled_ot") { %><%= r.date %> · <%= r.fromTime %>–<%= r.toTime %> (<%= r.hours %>h)<% } else { %>—<% } %>
          <% if (r.requesterRemarks) { %><div class="oh-muted" style="font-size:0.78rem">“<%= r.requesterRemarks %>”</div><% } %>
          <% if (r.recommendedByName) { %><div class="oh-muted" style="font-size:0.78rem">rec. by <%= r.recommendedByName %></div><% } %>
        </td>
        <td><%= r.requestedByName %><div class="oh-muted" style="font-size:0.78rem"><%= ts(r.requestedAt) %></div></td>
        <td><span class="oh-stat"><span class="oh-stat__dot" style="background: <%= dot[r.status] || 'var(--c-text-muted)' %>"></span><%= r.status %></span></td>
        <td class="oh-people__actcol"><%- include('actions', { r: r, canRecommend: canRecommend, canDecide: canDecide }) %></td>
      </tr>
      <% }); %>
    </tbody>
  </table>
</div>
<% } %>

<%- include('../partials/app-bottom') %>
