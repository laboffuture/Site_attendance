<%- include('partials/app-top', { title: title, active: active }) %>
<%
  function ts(d) { return d ? new Date(d).toLocaleString("en-GB", { timeZone: "Asia/Kolkata", dateStyle: "medium", timeStyle: "short" }) : ""; }
%>

<div class="oh-page-header oh-page-header--row">
  <div>
    <h1 class="oh-page-title">Dashboard</h1>
    <p class="oh-page-subtitle">Welcome, <%= currentUser.name %> · Scope: <%= scopeLabel %></p>
  </div>
  <% if (mySites && mySites.length > 1) { %>
  <form method="get" action="/dashboard" class="oh-dash-filter">
    <select class="oh-select" name="siteId" onchange="this.form.submit()" aria-label="Filter by site">
      <option value="">All my sites</option>
      <% mySites.forEach(function (s) { %>
      <option value="<%= s._id %>" <%= selectedSiteId === String(s._id) ? "selected" : "" %>><%= s.name %> (<%= s.code %>)</option>
      <% }); %>
    </select>
  </form>
  <% } %>
</div>

<div class="oh-card-grid">
  <div class="oh-card">
    <div class="oh-card__label">Present Today</div>
    <div class="oh-card__value"><%= stats.todayCount %></div>
  </div>
  <a class="oh-card oh-card--link" href="/overtime?status=pending">
    <div class="oh-card__label">Pending Overtime</div>
    <div class="oh-card__value"><%= stats.pendingOT %></div>
  </a>
  <a class="oh-card oh-card--link" href="/flags">
    <div class="oh-card__label">Flagged Events</div>
    <div class="oh-card__value"><%= stats.unresolvedFlags %></div>
  </a>
  <div class="oh-card">
    <div class="oh-card__label">Active Workers</div>
    <div class="oh-card__value"><%= stats.todayCount %> <span class="oh-card__of">/ <%= stats.activeWorkers %></span></div>
    <div class="oh-card__note"><%= stats.activeWorkers ? Math.round((stats.todayCount / stats.activeWorkers) * 100) : 0 %>% present today</div>
  </div>
</div>

<% if (rollup) { %>
<div class="oh-card oh-stack">
  <div class="oh-section-header">
    <span class="oh-section-title">By branch &amp; site</span>
    <span class="oh-muted">present = scanned in today</span>
  </div>
  <% if (rollup.length) { %>
  <table class="oh-table oh-rollup">
    <thead>
      <tr>
        <th>Branch / Site</th>
        <th class="num">Present</th><th class="num">Active</th>
        <th class="num">OT pending</th><th class="num">Flags</th>
      </tr>
    </thead>
    <tbody>
      <% rollup.forEach(function (b, i) { %>
      <tr class="oh-rollup-branch" data-branch="<%= i %>">
        <td><span class="oh-caret">&#9660;</span> <%= b.branchName %></td>
        <td class="num"><%= b.totals.present %></td>
        <td class="num"><%= b.totals.active %></td>
        <td class="num"><%= b.totals.otPending %>h</td>
        <td class="num"><%= b.totals.flags %></td>
      </tr>
      <% b.sites.forEach(function (s) { %>
      <tr class="oh-rollup-site" data-branch="<%= i %>">
        <td class="oh-rollup-sitename"><%= s.siteName %> <span class="oh-muted">(<%= s.code %>)</span></td>
        <td class="num"><%= s.present %></td>
        <td class="num"><%= s.active %></td>
        <td class="num <%= s.otPending > 0 ? 'oh-num-warn' : '' %>"><%= s.otPending %>h</td>
        <td class="num <%= s.flags > 0 ? 'oh-num-danger' : '' %>"><%= s.flags %></td>
      </tr>
      <% }); %>
      <% }); %>
    </tbody>
  </table>
  <% } else { %>
  <p class="oh-muted">No sites in your scope yet.</p>
  <% } %>
</div>
<% } %>

<div class="oh-chart-grid">
  <div class="oh-card">
    <div class="oh-card__label">Attendance — last 14 days</div>
    <% var d = charts.trend; var arrow = d.deltaDir === "up" ? "▲" : d.deltaDir === "down" ? "▼" : "—"; %>
    <div class="oh-chart-headline">
      <span class="oh-chart-big"><%= d.today %></span>
      <span class="oh-chart-sub">
        today · avg <%= d.avg %>/day
        <% if (d.deltaDir !== "flat") { %>
        · <span class="oh-trend oh-trend--<%= d.deltaDir %>"><%= arrow %> <%= Math.abs(d.deltaPct) %>%</span> vs last wk
        <% } %>
      </span>
    </div>
    <div class="oh-chart-box"><canvas id="trendChart"></canvas></div>
  </div>
  <div class="oh-card">
    <div class="oh-card__label">Overtime hours by site</div>
    <div class="oh-chart-box"><canvas id="otChart"></canvas></div>
  </div>
  <div class="oh-card">
    <div class="oh-card__label">Active headcount by designation</div>
    <div class="oh-chart-box"><canvas id="desigChart"></canvas></div>
  </div>
</div>

<div class="oh-card oh-stack">
  <div class="oh-section-header">
    <span class="oh-section-title">Recent flagged events</span>
    <a class="oh-btn oh-btn--small" href="/flags">View all</a>
  </div>
  <% if (flags.length) { %>
  <table class="oh-table">
    <thead><tr><th>When</th><th>Worker</th><th>Attempted at</th><th>Assigned to</th></tr></thead>
    <tbody>
      <% flags.forEach(function (f) { %>
      <tr>
        <td><%= ts(f.timestamp) %></td>
        <td><%= f.workerName || "—" %></td>
        <td><%= f.attemptedSiteName || "—" %></td>
        <td><%= f.homeSiteName || "—" %></td>
      </tr>
      <% }); %>
    </tbody>
  </table>
  <% } else { %>
  <p class="oh-muted">No unresolved flags. 🎉</p>
  <% } %>
</div>

<script>
  // Collapse/expand a branch's site rows in the rollup table.
  document.querySelectorAll(".oh-rollup-branch").forEach(function (row) {
    row.addEventListener("click", function () {
      var key = row.getAttribute("data-branch");
      var collapsed = row.classList.toggle("collapsed");
      document.querySelectorAll('.oh-rollup-site[data-branch="' + key + '"]').forEach(function (s) {
        s.style.display = collapsed ? "none" : "";
      });
    });
  });

  window.__CHARTS__ = <%- JSON.stringify(charts) %>;
</script>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.6/dist/chart.umd.min.js"></script>
<script src="/static/js/dashboard-charts.js"></script>

<%- include('partials/app-bottom') %>
