<%- include('partials/app-top', { title: title, active: active }) %>
<%
  function ts(d) { return d ? new Date(d).toLocaleString("en-GB", { timeZone: "Asia/Kolkata", dateStyle: "medium", timeStyle: "short" }) : ""; }
%>

<div class="oh-page-header oh-page-header--row">
  <div>
    <h1 class="oh-page-title">Dashboard</h1>
    <p class="oh-page-subtitle">Welcome, <%= currentUser.name %> · Scope: <%= scopeLabel %></p>
  </div>
  <% if (mySites && mySites.length > 1) { %>
  <form method="get" action="/dashboard" class="oh-dash-filter">
    <select class="oh-select" name="siteId" onchange="this.form.submit()" aria-label="Open a site">
      <option value="">All my sites</option>
      <% mySites.forEach(function (s) { %>
      <option value="<%= s._id %>"><%= s.name %> (<%= s.code %>)</option>
      <% }); %>
    </select>
  </form>
  <% } %>
</div>

<% if (!seesAll && myLocations && myLocations.length) { %>
<div class="oh-loc-bar">
  <span class="oh-loc-bar__label"><%= myLocations.length %> assigned location<%= myLocations.length > 1 ? "s" : "" %>:</span>
  <% myLocations.forEach(function (loc) { %><span class="oh-loc-chip"><span class="material-icons">place</span><%= loc %></span><% }); %>
</div>
<% } %>

<div class="oh-card-grid">
  <div class="oh-card">
    <div class="oh-card__label">Present Today</div>
    <div class="oh-card__value"><%= stats.todayCount %></div>
  </div>
  <a class="oh-card oh-card--link" href="/overtime?status=pending">
    <div class="oh-card__label">Pending Overtime</div>
    <div class="oh-card__value"><%= stats.pendingOT %></div>
  </a>
  <a class="oh-card oh-card--link" href="/flags">
    <div class="oh-card__label">Flagged Events</div>
    <div class="oh-card__value"><%= stats.unresolvedFlags %></div>
  </a>
  <div class="oh-card">
    <div class="oh-card__label">Active Workers</div>
    <div class="oh-card__value"><%= stats.todayCount %> <span class="oh-card__of">/ <%= stats.activeWorkers %></span></div>
    <div class="oh-card__note"><%= stats.activeWorkers ? Math.round((stats.todayCount / stats.activeWorkers) * 100) : 0 %>% present today</div>
  </div>
</div>

<!-- Executive gauges (added on top — radialBar via ApexCharts) -->
<% if (typeof gauges !== 'undefined' && gauges.length) { %>
<div class="oh-chart-grid">
  <% gauges.forEach(function (g) { %>
  <div class="oh-card">
    <div class="oh-card__label"><%= g.label %></div>
    <div class="oh-gauge" id="gauge-<%= g.id %>" data-value="<%= g.value %>" data-unit="<%= g.unit %>"></div>
  </div>
  <% }); %>
</div>
<% } %>

<% if (rollup) { %>
<section class="oh-stack" aria-label="Branches">
  <div class="oh-section-header">
    <span class="oh-section-title">Branches</span>
    <span class="oh-muted">Tap a branch to see its sites · present = scanned in today</span>
  </div>
  <% if (rollup.length) { %>
  <div class="oh-dash-branches">
    <% rollup.forEach(function (b, i) { %>
    <section class="oh-dash-branch" data-branch="<%= i %>">
      <button type="button" class="oh-dash-box" aria-expanded="false" aria-controls="dash-sites-<%= i %>">
        <span class="oh-dash-box__head">
          <span class="oh-dash-box__name"><%= b.branchName %></span>
          <span class="oh-dash-box__caret" aria-hidden="true">&#9656;</span>
        </span>
        <span class="oh-dash-box__count"><%= b.totals.active %> <span class="oh-dash-box__count-unit">workers</span></span>
        <span class="oh-dash-box__sub">
          <strong><%= b.totals.present %></strong> in · OT <%= b.totals.otPending %>h
        </span>
        <% if (b.totals.flags > 0) { %>
        <span class="oh-dash-box__chip">&#9873; <%= b.totals.flags %></span>
        <% } %>
      </button>
      <div class="oh-dash-sites" id="dash-sites-<%= i %>" role="region" aria-label="Sites in <%= b.branchName %>">
        <% b.sites.forEach(function (s) { var pct = s.active > 0 ? Math.round((s.present / s.active) * 100) : 0; %>
        <a class="oh-hier__tile oh-dash-tile" href="/dashboard?siteId=<%= s.siteId %>">
          <div class="oh-hier__site"><%= s.siteName %></div>
          <div class="oh-hier__code"><%= s.code %></div>
          <div class="oh-hier__num"><%= s.active %></div>
          <div class="oh-hier__num-label">workers</div>
          <div class="oh-hier__present <%= s.present > 0 ? 'is-in' : '' %>"><%= s.present %> present today</div>
          <% if (s.otPending > 0 || s.flags > 0) { %>
          <div class="oh-hier__chips">
            <% if (s.otPending > 0) { %><span class="oh-hier__chip oh-hier__chip--ot">OT <%= s.otPending %>h</span><% } %>
            <% if (s.flags > 0) { %><span class="oh-hier__chip oh-hier__chip--flag">&#9873; <%= s.flags %></span><% } %>
          </div>
          <% } %>
          <div class="oh-hier__bar"><span class="oh-hier__bar-fill" style="width: <%= pct %>%"></span></div>
        </a>
        <% }); %>
      </div>
    </section>
    <% }); %>
  </div>
  <% } else { %>
  <p class="oh-muted">No sites in your scope yet.</p>
  <% } %>
</section>
<% } %>

<% if (charts.presenceBySite) { %>
<div class="oh-card">
  <div class="oh-card__label">Present vs active — by site (today)</div>
  <div class="oh-chart-box"><div id="presenceChart"></div></div>
</div>
<% } %>

<div class="oh-chart-grid">
  <div class="oh-card">
    <div class="oh-card__label">Attendance — last 14 days</div>
    <% var d = charts.trend; var arrow = d.deltaDir === "up" ? "▲" : d.deltaDir === "down" ? "▼" : "—"; %>
    <div class="oh-chart-headline">
      <span class="oh-chart-big"><%= d.today %></span>
      <span class="oh-chart-sub">
        today · avg <%= d.avg %>/day
        <% if (d.deltaDir !== "flat") { %>
        · <span class="oh-trend oh-trend--<%= d.deltaDir %>"><%= arrow %> <%= Math.abs(d.deltaPct) %>%</span> vs last wk
        <% } %>
      </span>
    </div>
    <div class="oh-chart-box"><div id="trendChart"></div></div>
  </div>
  <div class="oh-card">
    <div class="oh-card__label">Overtime hours by site</div>
    <div class="oh-chart-box"><div id="otChart"></div></div>
  </div>
  <div class="oh-card">
    <div class="oh-card__label">Active headcount by designation</div>
    <div class="oh-chart-box"><div id="desigChart"></div></div>
  </div>
</div>

<div class="oh-card oh-stack">
  <div class="oh-section-header">
    <span class="oh-section-title">Recent flagged events</span>
    <a class="oh-btn oh-btn--small" href="/flags">View all</a>
  </div>
  <% if (flags.length) { %>
  <table class="oh-table oh-table--cards">
    <thead><tr><th>When</th><th>Worker</th><th>Attempted at</th><th>Assigned to</th></tr></thead>
    <tbody>
      <% flags.forEach(function (f) { %>
      <tr>
        <td><%= ts(f.timestamp) %></td>
        <td data-label="Worker"><%= f.workerName || "—" %></td>
        <td data-label="Attempted at"><%= f.attemptedSiteName || "—" %></td>
        <td data-label="Assigned to"><%= f.homeSiteName || "—" %></td>
      </tr>
      <% }); %>
    </tbody>
  </table>
  <% } else { %>
  <p class="oh-muted">No unresolved flags. 🎉</p>
  <% } %>
</div>

<script>
  // Progressive disclosure: tapping a branch box reveals its site tiles.
  document.querySelectorAll(".oh-dash-box").forEach(function (box) {
    box.addEventListener("click", function () {
      var branch = box.closest(".oh-dash-branch");
      var open = branch.classList.toggle("is-open");
      box.setAttribute("aria-expanded", open ? "true" : "false");
    });
  });

  window.__CHARTS__ = <%- JSON.stringify(charts) %>;
</script>
<script src="https://cdn.jsdelivr.net/npm/apexcharts@3.54.1/dist/apexcharts.min.js"></script>
<script src="/static/js/dashboard-charts.js"></script>
<script src="/static/js/dashboard-gauges.js"></script>

<%- include('partials/app-bottom') %>
