<%- include('../partials/app-top', { title: title, active: active }) %>
<% var badgeFor = { pending: "warning", approved: "success", rejected: "danger", none: "muted" }; %>

<div class="oh-page-header">
  <h1 class="oh-page-title">Attendance</h1>
  <p class="oh-page-subtitle">Mark or correct attendance manually — for failed scans, missed clock-outs, or fixes. Automatic scans happen at the Site Station.</p>
</div>

<% if (!sites.length) { %>
<div class="oh-card"><p class="oh-muted">No sites are assigned to you.</p></div>
<% } else { %>

<div class="oh-card oh-stack">
  <form class="oh-form-inline" method="get" action="/attendance">
    <div class="oh-input-group">
      <label class="oh-label" for="siteId">Site</label>
      <select class="oh-select" id="siteId" name="siteId" onchange="this.form.submit()">
        <% sites.forEach(function (s) { %>
        <option value="<%= s._id %>" <%= String(s._id) === String(site._id) ? "selected" : "" %>><%= s.name %> (<%= s.code %>)</option>
        <% }); %>
      </select>
    </div>
    <div class="oh-input-group">
      <label class="oh-label" for="date">Date</label>
      <input class="oh-input" id="date" type="date" name="date" value="<%= date %>" onchange="this.form.submit()" />
    </div>
    <noscript><button class="oh-btn oh-btn--secondary" type="submit">Go</button></noscript>
  </form>

  <div class="oh-section-header">
    <span class="oh-section-title"><%= site.name %> · <%= date %></span>
    <span class="oh-muted">shift <%= site.standardStartTime %>–<%= site.standardEndTime %> · <%= rows.length %> active worker(s)</span>
  </div>

  <% if (rows.length) { %>
  <!-- mobile: roster cards -->
  <div class="oh-only-mobile oh-m-list">
    <% rows.forEach(function (r) {
      var st = r.outHM ? ["OUT", "secondary"] : (r.inHM ? ["IN", "success"] : ["ABSENT", "danger"]);
    %>
    <form class="oh-m-card" method="post" action="/attendance/mark">
      <input type="hidden" name="workerId" value="<%= r.workerId %>" />
      <input type="hidden" name="date" value="<%= date %>" />
      <div class="oh-m-row">
        <span class="oh-m-avatar"><%= r.name.split(' ').map(function (x) { return x[0]; }).join('').slice(0, 2).toUpperCase() %></span>
        <span class="oh-m-grow">
          <span class="oh-m-name">
            <%= r.name %>
            <% if (r.source === "manual") { %><span class="oh-m-badge oh-badge--warning">M</span><% } %>
          </span>
          <span class="oh-m-sub"><%= r.empRegNo %> · <%= r.designationName %></span>
        </span>
        <span class="oh-m-badge oh-badge--<%= st[1] %>"><%= st[0] %></span>
      </div>
      <div class="oh-m-boxes">
        <label class="oh-m-box"><span class="oh-m-box__k">In</span><input type="time" name="inTime" value="<%= r.inHM %>" /></label>
        <label class="oh-m-box"><span class="oh-m-box__k">Out</span><input type="time" name="outTime" value="<%= r.outHM %>" /></label>
      </div>
      <% if (r.totalHours != null || r.otHours > 0) { %>
      <div class="oh-m-sub" style="margin-top:0.5rem;">
        Total <%= r.totalHours != null ? r.totalHours + "h" : "—" %><% if (r.otHours > 0) { %> · OT <%= r.otHours %>h (<%= r.otStatus %>)<% } %>
      </div>
      <% } %>
      <div class="oh-m-actions">
        <button class="oh-btn oh-btn--small oh-btn--secondary" type="submit">Save</button>
      </div>
    </form>
    <% }); %>
  </div>

  <table class="oh-table oh-only-desktop">
    <thead>
      <tr><th>Reg No</th><th>Name</th><th>In</th><th>Out</th><th>Total</th><th>OT</th><th>Src</th><th class="oh-col-action">Save</th></tr>
    </thead>
    <tbody>
      <% rows.forEach(function (r) { %>
      <tr>
        <form method="post" action="/attendance/mark" class="oh-att-row">
          <input type="hidden" name="workerId" value="<%= r.workerId %>" />
          <input type="hidden" name="date" value="<%= date %>" />
          <td><span class="oh-badge oh-badge--muted"><%= r.empRegNo %></span></td>
          <td><%= r.name %><br /><span class="oh-muted"><%= r.designationName %></span></td>
          <td><input class="oh-input oh-input--time" type="time" name="inTime" value="<%= r.inHM %>" /></td>
          <td><input class="oh-input oh-input--time" type="time" name="outTime" value="<%= r.outHM %>" /></td>
          <td><%= r.totalHours != null ? r.totalHours + "h" : "—" %></td>
          <td>
            <% if (r.otHours > 0) { %><%= r.otHours %>h
            <span class="oh-badge oh-badge--<%= badgeFor[r.otStatus] %>"><%= r.otStatus %></span><% } else { %>—<% } %>
          </td>
          <td>
            <% if (r.source === "manual") { %><span class="oh-badge oh-badge--warning" title="Marked manually">M</span>
            <% } else if (r.source === "scan") { %><span class="oh-badge oh-badge--muted" title="Face scan">scan</span>
            <% } else { %><span class="oh-muted">—</span><% } %>
          </td>
          <td class="oh-col-action"><button class="oh-btn oh-btn--small oh-btn--secondary" type="submit">Save</button></td>
        </form>
      </tr>
      <% }); %>
    </tbody>
  </table>
  <p class="oh-muted">Set In to mark present; add Out to compute total &amp; overtime. Manually saved rows are tagged <strong>M</strong> and flagged in reports.</p>
  <% } else { %>
  <p class="oh-muted">No active workers enrolled at this site yet.</p>
  <% } %>
</div>
<% } %>

<%- include('../partials/app-bottom') %>
