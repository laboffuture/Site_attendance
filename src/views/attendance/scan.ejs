<!DOCTYPE html>
<html lang="en">
  <head>
    <%- include('../partials/head', { title: title }) %>
  </head>
  <body>
    <div class="oh-kiosk">
      <header class="oh-kiosk__header">
        <div class="oh-kiosk__site">Log Attendance</div>
        <div class="oh-scan-controls">
          <label for="siteSelect" class="oh-scan-controls__label">Site you're at</label>
          <select id="siteSelect" class="oh-select oh-scan-controls__select">
            <% sites.forEach(function (s) { var fenced = s.latitude != null && s.longitude != null && s.geofenceRadiusMeters != null; %>
            <option value="<%= s._id %>" data-fenced="<%= fenced ? '1' : '0' %>"><%= s.name %> (<%= s.code %>)<%= fenced ? ' • geofenced' : '' %></option>
            <% }); %>
          </select>
          <a class="oh-btn oh-btn--small" href="/requests/new">Raise request</a>
          <a class="oh-btn oh-btn--small oh-scan-controls__done" href="/attendance">Done</a>
        </div>
      </header>

      <main class="oh-kiosk__main">
        <% if (!sites.length) { %>
        <div class="oh-scan-empty">
          <div class="oh-result oh-result--warn">No sites are assigned to you — ask HR or management to assign one.</div>
        </div>
        <% } else { %>
        <div class="oh-scan-split">
          <div class="oh-scan-stage">
            <div class="oh-scan-actions oh-scan-io" style="margin-bottom:0.6rem">
              <button id="att-in" type="button" class="oh-btn oh-btn--success oh-io-btn">Clock IN</button>
              <button id="att-out" type="button" class="oh-btn oh-btn--secondary oh-io-btn">Clock OUT</button>
            </div>
            <div class="oh-scan-stage__video-frame">
              <video id="video" class="oh-kiosk__video" autoplay playsinline muted></video>
              <canvas id="canvas" hidden></canvas>
            </div>
            <div id="result" class="oh-result oh-result--idle">Pick Clock IN or Clock OUT and your site, then step up.</div>
            <div class="oh-scan-actions">
              <button id="autoToggle" type="button" class="oh-btn oh-btn--small oh-autotoggle is-on" data-on="1">Auto-scan: On</button>
              <button id="scanBtn" class="oh-btn oh-btn--secondary oh-scan-btn">Scan now</button>
            </div>
            <div class="oh-scan-stage__notes">
              <p id="camNote" class="oh-muted"></p>
              <div id="geoNote" class="oh-muted"></div>
            </div>
          </div>

          <aside class="oh-scan-log">
            <div class="oh-scan-log__head">Logged today <span class="oh-scan-log__count"><%= logged.length %></span></div>
            <% if (logged.length) { %>
            <ul class="oh-scan-log__list">
              <% logged.forEach(function (l) { %>
              <li class="oh-scan-log__item">
                <span class="oh-scan-log__badge oh-scan-log__badge--<%= l.state === 'OUT' ? 'out' : 'in' %>"><%= l.state %></span>
                <span class="oh-scan-log__who">
                  <span class="oh-scan-log__name"><%= l.workerName %></span>
                  <span class="oh-scan-log__sub"><%= l.empRegNo %> · <%= l.siteName %></span>
                </span>
                <span class="oh-scan-log__time"><%= l.state === 'OUT' ? l.outHM : l.inHM %></span>
              </li>
              <% }); %>
            </ul>
            <% } else { %>
            <p class="oh-muted">No attendance logged yet today. Scans appear here as they happen.</p>
            <% } %>
          </aside>
        </div>
        <% } %>
      </main>
    </div>
    <script src="/static/vendor/face-api.js"></script>
    <script src="/static/js/face-autoscan.js"></script>
    <script src="/static/js/attendance-scan.js"></script>
  </body>
</html>
