<%- include('../partials/app-top', { title: title, active: active }) %>
<% var dot = { scanned: "var(--c-text-muted)", submitted: "var(--c-warning)", recommended: "var(--c-accent)", approved: "var(--c-success)", rejected: "var(--c-danger)" }; %>
<% function actionable(r) { return (canCorrect && !r.voided) || (canReject && (r.status === "submitted" || r.status === "recommended")); } %>
<%- include('../partials/breadcrumb', { back: '/regularization', trail: [ { label: 'Attendance corrections', href: '/regularization' }, { label: siteName + ' · ' + date } ] }) %>

<div class="oh-page-header oh-page-header--row">
  <div>
    <h1 class="oh-page-title"><%= siteName %></h1>
    <p class="oh-page-subtitle"><%= date %> · <span class="oh-stat"><span class="oh-stat__dot" style="background: <%= dot[status] || 'var(--c-text-muted)' %>"></span><%= status %></span></p>
  </div>
  <div class="oh-actions">
    <% if (canRecommend && status === "submitted") { %>
    <form method="post" action="/regularization/<%= siteId %>/<%= date %>/recommend" onsubmit="return confirm('Recommend this day to HR?')" style="margin:0"><button class="oh-btn oh-btn--accent" type="submit"><span class="material-icons">thumb_up</span> Recommend day</button></form>
    <% } %>
    <% if (canApprove && status === "recommended") { %>
    <form method="post" action="/regularization/<%= siteId %>/<%= date %>/approve" onsubmit="return confirm('Approve this day? This also approves the day\'s overtime.')" style="margin:0"><button class="oh-btn oh-btn--accent" type="submit"><span class="material-icons">check_circle</span> Approve day</button></form>
    <% } %>
  </div>
</div>

<% if (status === "approved") { %><div class="oh-alert oh-alert--success">Day approved — overtime cleared to payroll.</div><% } %>

<!-- Shared single-open editor drawer. One panel per actionable worker, hidden until
     its #edit-<id> fragment is targeted (zero-JS single-open). Rendered ONCE here so
     it serves both the desktop table and the mobile cards; never duplicated. -->
<div class="oh-editor" id="corrections-top">
  <% rows.forEach(function (r) { if (!actionable(r)) return; %>
  <div class="oh-editpanel" id="edit-<%= r.id %>" style="--spine: <%= dot[r.status] || 'var(--c-border)' %>">
    <div class="oh-editpanel__head">
      <div class="oh-editpanel__id">
        <span class="oh-person__name"><%= r.workerName %></span>
        <span class="oh-person__id"><%= r.empRegNo %></span>
        <span class="oh-stat"><span class="oh-stat__dot" style="background: <%= dot[r.status] || 'var(--c-text-muted)' %>"></span><%= r.status %></span>
        <% if (!r.outHM && !r.voided) { %><span class="oh-badge oh-badge--warning">No OUT — unresolved</span><% } %>
        <% if (r.voided) { %><span class="oh-badge oh-badge--muted">Voided</span><% } %>
        <% if (r.verifiedAt) { %><span class="oh-badge oh-badge--success">Verified</span><% } %>
      </div>
      <a class="oh-icon-btn" href="#corrections-top" aria-label="Close editor for <%= r.workerName %>" title="Close"><span class="material-icons">close</span></a>
    </div>

    <% if (canCorrect && !r.voided) { %>
    <section class="oh-form-section">
      <h3 class="oh-kv-section__title">Correct attendance</h3>
      <form class="oh-frow" method="post" action="/regularization/worker/<%= r.id %>/correct">
        <label class="oh-frow__label" for="in-<%= r.id %>">Times &amp; shift<span class="oh-muted">In / Out, shift and a reason</span></label>
        <div class="oh-frow__field oh-ot-actions" style="flex-wrap:wrap">
          <input id="in-<%= r.id %>" class="oh-input oh-input--xs oh-time24" type="text" inputmode="numeric" placeholder="HH:MM" pattern="([01][0-9]|2[0-3]):[0-5][0-9]" maxlength="5" name="inHM" value="<%= r.inHM %>" title="In time" />
          <input class="oh-input oh-input--xs oh-time24" type="text" inputmode="numeric" placeholder="HH:MM" pattern="([01][0-9]|2[0-3]):[0-5][0-9]" maxlength="5" name="outHM" value="<%= r.outHM %>" title="Out time" />
          <select class="oh-select oh-input--xs" name="shiftType" title="Shift">
            <option value="day" <%= r.shiftType === "day" ? "selected" : "" %>>Day</option>
            <option value="night" <%= r.shiftType === "night" ? "selected" : "" %>>Night</option>
            <option value="sunday" <%= r.shiftType === "sunday" ? "selected" : "" %>>Sunday</option>
          </select>
          <input class="oh-input" style="flex:1 1 180px;min-width:0" type="text" name="reason" placeholder="Reason" title="Reason for correction" />
          <button class="oh-btn oh-btn--small oh-btn--accent" type="submit">Save</button>
        </div>
      </form>
    </section>
    <% } %>

    <section class="oh-form-section">
      <h3 class="oh-kv-section__title">Disposition</h3>
      <% if (canCorrect && !r.voided) { %>
      <form class="oh-frow" method="post" action="/regularization/worker/<%= r.id %>/verify">
        <label class="oh-frow__label" for="note-<%= r.id %>">Verify scans<span class="oh-muted">Mark the scanned times correct</span></label>
        <div class="oh-frow__field oh-frow__pair">
          <input id="note-<%= r.id %>" class="oh-input" type="text" name="note" placeholder="Optional note" title="Optional verify note" />
          <button class="oh-btn oh-btn--small" type="submit">Verify</button>
        </div>
      </form>
      <form class="oh-frow" method="post" action="/regularization/worker/<%= r.id %>/void">
        <label class="oh-frow__label" for="void-<%= r.id %>">Void day<span class="oh-muted">Excludes this worker-day from pay</span></label>
        <div class="oh-frow__field oh-frow__pair">
          <input id="void-<%= r.id %>" class="oh-input" type="text" name="reason" placeholder="Void reason" title="Reason for voiding" />
          <button class="oh-btn oh-btn--small oh-btn--danger" type="submit">Void</button>
        </div>
      </form>
      <% } %>
      <% if (canReject && (r.status === "submitted" || r.status === "recommended")) { %>
      <form class="oh-frow" method="post" action="/regularization/worker/<%= r.id %>/reject">
        <label class="oh-frow__label" for="rej-<%= r.id %>">Reject — send back<span class="oh-muted">Returns this worker to the supervisor</span></label>
        <div class="oh-frow__field oh-frow__pair">
          <input id="rej-<%= r.id %>" class="oh-input" type="text" name="reason" placeholder="Reason for rejection" required title="Reason for rejection" />
          <button class="oh-btn oh-btn--small oh-btn--danger" type="submit">Reject</button>
        </div>
      </form>
      <% } %>
    </section>
  </div>
  <% }); %>
</div>

<!-- mobile -->
<div class="oh-only-mobile">
  <% if (!rows.length) { %><div class="oh-m-section"><p class="oh-muted">No attendance for this day.</p></div><% } else { %>
  <div class="oh-m-section"><div class="oh-m-list">
    <% rows.forEach(function (r) { %>
    <div class="oh-m-card" style="--spine: <%= dot[r.status] || 'var(--c-border)' %>;border-left:3px solid var(--spine)">
      <div class="oh-m-row" style="justify-content:space-between;align-items:flex-start">
        <span class="oh-m-grow"><span class="oh-m-name"><%= r.workerName %></span><span class="oh-m-sub"><%= r.empRegNo %> · in <%= r.inHM || '—' %> · out <%= r.outHM || '—' %></span></span>
        <span class="oh-m-badge oh-badge--muted"><%= r.status %></span>
      </div>
      <div class="oh-m-sub" style="margin-top:0.4rem"><%= r.totalHours != null ? r.totalHours + 'h total' : '—' %><%= r.otHours > 0 ? ' · OT ' + r.otHours + 'h' : '' %></div>
      <div class="oh-m-row" style="gap:0.35rem;flex-wrap:wrap;margin-top:0.4rem">
        <% if (!r.outHM && !r.voided) { %><span class="oh-m-badge oh-badge--warning">No OUT — unresolved</span><% } %>
        <% if (r.voided) { %><span class="oh-m-badge oh-badge--muted">Voided</span><% } %>
        <% if (r.verifiedAt) { %><span class="oh-m-badge oh-badge--success">Verified</span><% } %>
        <% if (r.status === "rejected" && r.rejectReason) { %><span class="oh-m-sub" style="width:100%">✕ <%= r.rejectReason %></span><% } %>
      </div>
      <% if (actionable(r)) { %>
      <div class="oh-m-actions"><a class="oh-btn oh-btn--small oh-btn--secondary" href="#edit-<%= r.id %>"><span class="material-icons">edit</span> Edit / resolve</a></div>
      <% } %>
    </div>
    <% }); %>
  </div></div>
  <% } %>
</div>

<!-- desktop -->
<div class="oh-card oh-card--flush oh-only-desktop">
  <% if (!rows.length) { %>
  <div class="oh-empty"><span class="material-icons">event_busy</span><p>No attendance for this day.</p></div>
  <% } else { %>
  <table class="oh-people">
    <thead><tr><th class="oh-people__spinecol"></th><th>Worker</th><th>In</th><th>Out</th><th>Total</th><th>OT</th><th>Status</th><% if (canReject || canCorrect) { %><th class="oh-people__actcol"></th><% } %></tr></thead>
    <tbody>
      <% rows.forEach(function (r) { %>
      <tr style="--spine: <%= dot[r.status] || 'var(--c-border)' %>">
        <td class="oh-people__spine"></td>
        <td>
          <span class="oh-person__txt"><span class="oh-person__name"><%= r.workerName %></span><span class="oh-person__id"><%= r.empRegNo %></span></span>
          <% if (r.status === "rejected" && r.rejectReason) { %><div class="oh-muted" style="font-size:0.78rem">✕ <%= r.rejectReason %></div><% } %>
        </td>
        <td><%= r.inHM || "—" %></td>
        <td>
          <%= r.outHM || "—" %>
          <% if (!r.outHM && !r.voided) { %><span class="oh-badge oh-badge--warning" style="display:block;margin-top:0.25rem">No OUT — unresolved</span><% } %>
        </td>
        <td><%= r.totalHours != null ? r.totalHours + "h" : "—" %></td>
        <td><%= r.otHours > 0 ? r.otHours + "h" : "—" %></td>
        <td>
          <span class="oh-stat"><span class="oh-stat__dot" style="background: <%= dot[r.status] || 'var(--c-text-muted)' %>"></span><%= r.status %></span>
          <% if (r.voided) { %><span class="oh-badge oh-badge--muted" style="display:block;margin-top:0.25rem">Voided</span><% } %>
          <% if (r.verifiedAt) { %><span class="oh-badge oh-badge--success" style="display:block;margin-top:0.25rem">Verified</span><% } %>
        </td>
        <% if (canReject || canCorrect) { %>
        <td class="oh-people__actcol">
          <% if (actionable(r)) { %>
          <a class="oh-icon-btn" href="#edit-<%= r.id %>" aria-label="Edit corrections for <%= r.workerName %>" title="Edit / resolve"><span class="material-icons">edit</span></a>
          <% } %>
        </td>
        <% } %>
      </tr>
      <% }); %>
    </tbody>
  </table>
  <% } %>
</div>

<% if (canCorrect && addableWorkers.length) { %>
<div class="oh-card" style="margin-top:1rem;padding:1rem">
  <div class="oh-card__label">Add a worker who didn't scan</div>
  <p class="oh-muted" style="margin:0.2rem 0 0.7rem;font-size:0.8rem">Creates a manual day (recommended) for Management to approve.</p>
  <form method="post" action="/regularization/<%= siteId %>/<%= date %>/create" class="oh-form-inline">
    <select class="oh-select" name="workerId" required title="Worker">
      <option value="">Select worker…</option>
      <% addableWorkers.forEach(function (w) { %><option value="<%= w.id %>"><%= w.name %> · <%= w.empRegNo %></option><% }); %>
    </select>
    <input class="oh-input oh-time24" type="text" inputmode="numeric" placeholder="HH:MM" pattern="([01][0-9]|2[0-3]):[0-5][0-9]" maxlength="5" name="inHM" required title="In time" />
    <input class="oh-input oh-time24" type="text" inputmode="numeric" placeholder="HH:MM" pattern="([01][0-9]|2[0-3]):[0-5][0-9]" maxlength="5" name="outHM" title="Out time (optional)" />
    <select class="oh-select oh-input--time" name="shiftType" title="Shift">
      <option value="day">Day</option>
      <option value="night">Night</option>
      <option value="sunday">Sunday</option>
    </select>
    <input class="oh-input" type="text" name="reason" placeholder="Reason (e.g. scanner down)" title="Reason" />
    <button class="oh-btn oh-btn--accent" type="submit"><span class="material-icons">person_add</span> Add day</button>
  </form>
</div>
<% } %>

<%- include('../partials/app-bottom') %>
