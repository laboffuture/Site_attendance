<%- include('../partials/app-top', { title: title, active: active }) %>
<% var tabs = [["submitted", "Awaiting PM"], ["recommended", "Awaiting HR"], ["decided", "Decided"]]; %>

<div class="oh-page-header">
  <h1 class="oh-page-title">Regularization</h1>
  <p class="oh-page-subtitle">Review a day's scanned attendance, then recommend (PM) and approve (HR). Approval also clears that day's overtime.</p>
</div>

<div class="oh-filter-tabs">
  <% tabs.forEach(function (tb) { %>
  <a class="oh-filter-tab <%= tab === tb[0] ? 'oh-filter-tab--active' : '' %>" href="/regularization?tab=<%= tb[0] %>"><%= tb[1] %></a>
  <% }); %>
</div>

<div class="oh-card">
  <% if (days.length) { %>
  <table class="oh-table oh-table--cards">
    <thead>
      <tr><th>Date</th><th>Site</th><th>Workers</th><th>OT (h)</th><th class="oh-col-action"></th></tr>
    </thead>
    <tbody>
      <% days.forEach(function (d) { %>
      <tr>
        <td><%= d.date %></td>
        <td data-label="Site"><%= d.siteName %></td>
        <td data-label="Workers"><%= d.n %></td>
        <td data-label="OT (h)"><%= d.ot > 0 ? d.ot.toFixed(2) : "—" %></td>
        <td class="oh-col-action"><a class="oh-btn oh-btn--small oh-btn--secondary" href="/regularization/<%= d.siteId %>/<%= d.date %>">Open</a></td>
      </tr>
      <% }); %>
    </tbody>
  </table>
  <% } else { %>
  <p class="oh-muted">Nothing in this queue.</p>
  <% } %>
</div>

<%- include('../partials/app-bottom') %>
