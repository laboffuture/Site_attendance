# Copy to .env and fill in real values.

PORT=3000

# MongoDB connection string.
# Local form:  mongodb://localhost:27017
# Atlas form:  mongodb+srv://<user>:<password>@<cluster>.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGODB_URI=mongodb://localhost:27017

DB_NAME=trgbi_attendance

# Long random string for signing session cookies. Generate one, e.g.:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
SESSION_SECRET=change-me-to-a-long-random-string

COMPANY_NAME=TRGBI

# IST "HH:MM" the nightly missed-clock-out sweep fires at (default 23:00).
SWEEP_TIME=23:00

# First admin created by `npm run seed` (Management / super admin).
SEED_ADMIN_NAME=TRGBI Admin
SEED_ADMIN_EMAIL=admin@trgbi.com
SEED_ADMIN_PASSWORD=ChangeMe123!
